@using Ayapos.EndUser.Services.Auth
@using Ayapos.EndUser.Services.Ui
@inject SessionState SessionState
@inject UiLanguageState UiLanguage

<nav class="section-tabs" aria-label="Main sections">
    <a class="@GetWorkspaceTabClass()" href="@GetWorkspaceHref()">@UiLanguage.Text("Workspace", "مساحة العمل")</a>

    @if (SessionState.CanAccessPos)
    {
        <a class="@GetPosTabClass()" href="/pos">@UiLanguage.Text("Point of Sale", "نقطة البيع")</a>
    }

    @if (SessionState.CanAccessCatalog)
    {
        <a class="@GetProductsTabClass()" href="/products">@UiLanguage.Text("Products", "المنتجات")</a>
    }

    @if (SessionState.CanAccessServices)
    {
        <a class="@GetServicesTabClass()" href="/services">@UiLanguage.Text("Services", "الخدمات")</a>
    }

    @if (SessionState.CanAccessCustomers)
    {
        <a class="@GetCustomersTabClass()" href="/customers">@UiLanguage.Text("Customers", "العملاء")</a>
    }

    @if (SessionState.CanAccessAppointments)
    {
        <a class="@GetAppointmentsTabClass()" href="/appointments">@UiLanguage.Text("Appointments", "المواعيد")</a>
    }

    @if (SessionState.CanAccessEmployees)
    {
        <a class="@GetEmployeesTabClass()" href="/employees">@UiLanguage.Text("Employees", "الموظفون")</a>
    }

    @if (SessionState.CanAccessExpenses)
    {
        <a class="@GetExpensesTabClass()" href="/expenses">@UiLanguage.Text("Expenses", "المصروفات")</a>
    }

    @if (SessionState.CanAccessCashier)
    {
        <a class="@GetCashierTabClass()" href="/cashier">@UiLanguage.Text("Cashier Session", "جلسة الكاشير")</a>
    }

    @if (SessionState.CanAccessInvoices)
    {
        <a class="@GetCreateInvoiceTabClass()" href="/invoices/create">@UiLanguage.Text("Create Invoice", "إنشاء فاتورة")</a>
        <a class="@GetInvoicesTabClass()" href="/invoices">@UiLanguage.Text("Invoices", "الفواتير")</a>
    }
</nav>

@code {
    private bool _initialized;

    [Parameter]
    public string Current { get; set; } = string.Empty;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _initialized)
            return;

        _initialized = true;
        await UiLanguage.InitializeAsync();
        StateHasChanged();
    }

    private string GetWorkspaceTabClass() => GetTabClass("workspace");
    private string GetPosTabClass() => GetTabClass("pos");
    private string GetProductsTabClass() => GetTabClass("products");
    private string GetServicesTabClass() => GetTabClass("services");
    private string GetCustomersTabClass() => GetTabClass("customers");
    private string GetAppointmentsTabClass() => GetTabClass("appointments");
    private string GetEmployeesTabClass() => GetTabClass("employees");
    private string GetExpensesTabClass() => GetTabClass("expenses");
    private string GetCashierTabClass() => GetTabClass("cashier");
    private string GetCreateInvoiceTabClass() => GetTabClass("create-invoice");
    private string GetInvoicesTabClass() => GetTabClass("invoices");

    private string GetWorkspaceHref()
        => SessionState.IsTenantAdmin ? "/tenant-admin" : "/workspace";

    private string GetTabClass(string tab)
        => Current == tab ? "section-tab active" : "section-tab";
}
