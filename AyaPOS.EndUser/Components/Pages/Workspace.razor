        if (IsHrRole)
        {
            return
            [
                new("TEAM", "Employees", "Attendance", "Manage staff files, attendance, shifts, and leave records.", "/employees"),
                new("BOOK", "Appointments", "Schedule board", "Follow planned visits and support the front desk workflow.", "/appointments"),
                new("CRM", "Customers", $"{CustomersCount} records", "Review active customers and recent branch activity.", "/customers"),
                new("SERVICE", "Services", $"{ServicesCount} visible", "Make sure service information is ready and current.", "/services"),
                new("CATALOG", "Products", $"{ProductsCount} visible", "Support the branch with product lookup when needed.", "/products")
            ];
        }

        return
        [
            new("TEAM", "Employees", "Attendance", "Manage staff files, attendance, shifts, and leave records.", "/employees"),
            new("POS", "Point of Sale", "Live selling", "Open the branch selling screen and move faster through checkout.", "/pos"),
            new("DRAWER", "Cashier Session", CashierStateLabel, "Check whether the drawer is open and what cash is expected.", "/cashier"),
            new("CRM", "Customers", $"{CustomersCount} records", "Review customer activity and branch relationship history.", "/customers"),
            new("SALE", "Invoices", $"{InvoicesCount} invoices", "Monitor live sales and outstanding payment activity.", "/invoices")
        ];
    }

    private IReadOnlyList<WorkspaceActionItem> BuildQuickActions()
    {
        if (IsCashierRole)
        {
            return
            [
