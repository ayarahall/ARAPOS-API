        return
        [
            new("TEAM", "Employees", "Open", "Track attendance, shifts, leave, and staff documents.", "/employees"),
            new("POS", "Point of Sale", "Open", "Launch the branch point-of-sale workflow.", "/pos"),
            new("DRAWER", "Cashier Session", CashierStateLabel, "Open, review, or close the branch drawer.", "/cashier"),
            new("SALE", "Create Invoice", "Start sale", "Create a new invoice with products and services.", "/invoices/create"),
            new("FOLLOW UP", "Review Invoices", $"{InvoicesCount}", "Track payment status and recent branch invoices.", "/invoices"),
            new("CRM", "Customers", $"{CustomersCount}", "Open customer records and add new walk-ins.", "/customers"),
            new("BOOK", "Appointments", "Open", "Review scheduled visits and branch calendar readiness.", "/appointments"),
            new("COST", "Expenses", "Open", "Track branch expense entries and operating notes.", "/expenses")
        ];
    }

    private static string GetServiceDisplayName(ServiceListItemModel service)
        => !string.IsNullOrWhiteSpace(service.NameEn)
            ? service.NameEn
            : !string.IsNullOrWhiteSpace(service.NameAr)
                ? service.NameAr
                : "Unnamed service";

    private IEnumerable<string> GetAvailableAreas()
    {
        if (SessionState.CanAccessCatalog)
            yield return "Products";

        if (SessionState.CanAccessServices)
            yield return "Services";

        if (SessionState.CanAccessCustomers)
            yield return "Customers";

        if (SessionState.CanAccessCashier)
            yield return "Cashier";

        if (SessionState.CanAccessInvoices)
            yield return "Invoices";

        if (SessionState.CanAccessEmployees)
            yield return "Employees";
    }

    private IReadOnlyList<WorkspaceBarItem> BuildTopSellerBars()
    {
        var items = TodayTopItems.Take(6).ToList();
        var maxValue = items.Count == 0 ? 0 : items.Max(item => item.TotalCents);
        return items
            .Select(item => new WorkspaceBarItem(
                item.Name,
                maxValue <= 0 ? "0%" : $"{Math.Max(8, Math.Round((item.TotalCents / (double)maxValue) * 100d, 0))}%",
                FormatMoney(item.TotalCents, item.CurrencyCode)))
            .ToList();
    }

    private IReadOnlyList<WorkspaceBarItem> BuildPaymentMethodBars()
    {
        var groups = RecentPayments
            .GroupBy(payment => MapPaymentMethod(payment.Method))
            .Select(group => new
            {
                Label = group.Key,
                AmountCents = group.Sum(item => item.AmountCents)
            })
            .OrderByDescending(group => group.AmountCents)
            .ToList();

        var maxValue = groups.Count == 0 ? 0 : groups.Max(item => item.AmountCents);
        return groups
            .Select(group => new WorkspaceBarItem(
                group.Label,
                maxValue <= 0 ? "0%" : $"{Math.Max(8, Math.Round((group.AmountCents / (double)maxValue) * 100d, 0))}%",
                FormatMoney(group.AmountCents)))
            .ToList();
    }

    private sealed record WorkspaceActionItem(
        string Badge,
        string Title,
        string Value,
        string Description,
        string Href);

    private sealed record WorkspaceActivityRow(
        string Type,
        string Primary,
        string Details,
        string WhenLabel);

    private sealed record WorkspaceBarItem(
        string Label,
        string Width,
        string Value);
}
