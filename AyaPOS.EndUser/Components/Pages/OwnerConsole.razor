    private async Task RefreshSelectedTenantAsync()
    {
        if (SelectedTenant is null)
            return;

        var selectedTenantId = SelectedTenant.Id;
        var selectedBranchId = SelectedBranch?.Id;

        await LoadTenantsAsync();
        SelectedTenant = Tenants.FirstOrDefault(x => x.Id == selectedTenantId);

        if (SelectedTenant is null)
        {
            SelectedTenantUsers = [];
            SelectedTenantUser = null;
            SelectedBranches = [];
            SelectedBranch = null;
            TenantBranchUsers = [];
            SelectedBranchUsers = [];
            SelectedBranchUser = null;
            return;
        }

        UpdateTenantLicenseModel = new UpdateTenantLicenseRequestModel
        {
            LicensePlan = SelectedTenant.LicensePlan,
            MaxUsers = SelectedTenant.MaxUsers
        };

        SelectedTenantUsers = (await PlatformAdminApiClient.GetTenantUsersAsync(OwnerSessionState, SelectedTenant.Id)).ToList();
        SelectedTenantUser = SelectedTenantUser is null
            ? null
            : SelectedTenantUsers.FirstOrDefault(x => x.Id == SelectedTenantUser.Id);
        SelectedBranches = (await PlatformAdminApiClient.GetBranchesAsync(OwnerSessionState, SelectedTenant.Id)).ToList();
        TenantBranchUsers = await LoadTenantBranchUsersAsync(SelectedTenant.Id);
        SelectedBranch = selectedBranchId.HasValue
            ? SelectedBranches.FirstOrDefault(x => x.Id == selectedBranchId.Value)
            : null;

        if (SelectedBranch is not null)
        {
            UpdateBranchModel = new UpdateBranchRequestModel
            {
                Name = SelectedBranch.Name,
                Code = SelectedBranch.Code,
                CurrencyCode = SelectedBranch.CurrencyCode,
                IsActive = SelectedBranch.IsActive
            };
            SelectedBranchStatusValue = SelectedBranch.IsActive ? "true" : "false";
            SelectedBranchUsers = (await PlatformAdminApiClient.GetBranchUsersAsync(OwnerSessionState, SelectedTenant.Id, SelectedBranch.Id)).ToList();
            EnrichBranchUsers(SelectedBranchUsers);
            SelectedBranchUser = SelectedBranchUser is null
                ? null
                : SelectedBranchUsers.FirstOrDefault(x => x.Id == SelectedBranchUser.Id);
        }
        else
        {
            SelectedBranchUsers = [];
            SelectedBranchUser = null;
            UpdateBranchModel = new UpdateBranchRequestModel();
            SelectedBranchStatusValue = "true";
        }
    }

    private async Task<List<PlatformBranchUserModel>> LoadTenantBranchUsersAsync(Guid tenantId)
    {
        var result = new List<PlatformBranchUserModel>();

        foreach (var branch in SelectedBranches)
        {
            var users = (await PlatformAdminApiClient.GetBranchUsersAsync(OwnerSessionState, tenantId, branch.Id)).ToList();
            foreach (var user in users)
            {
                user.BranchName = branch.Name;
                user.BranchCode = branch.Code;
                result.Add(user);
            }
        }

        return result
            .OrderBy(user => user.BranchName, StringComparer.OrdinalIgnoreCase)
            .ThenBy(user => user.Username, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    private void EnrichBranchUsers(List<PlatformBranchUserModel> users)
    {
        foreach (var user in users)
        {
            var branch = SelectedBranches.FirstOrDefault(x => x.Id == user.BranchId);
            user.BranchName = branch?.Name ?? SelectedBranch?.Name ?? string.Empty;
            user.BranchCode = branch?.Code ?? SelectedBranch?.Code ?? string.Empty;
        }
    }

    private static string DisplayBranchName(PlatformBranchUserModel user)
        => string.IsNullOrWhiteSpace(user.BranchName)
            ? "Unknown branch"
            : string.IsNullOrWhiteSpace(user.BranchCode)
                ? user.BranchName
                : $"{user.BranchName} ({user.BranchCode})";

    private async Task OnUserPlanChanged(PlatformTenantUserModel user, string? newPlan)
    {
        if (SelectedTenant is null || string.IsNullOrWhiteSpace(newPlan))
            return;

        IsBusy = true;
        ErrorMessage = string.Empty;
        FlashMessage = string.Empty;

        try
        {
            await PlatformAdminApiClient.UpdateTenantUserLicenseAsync(OwnerSessionState, SelectedTenant.Id, user.Id, new UpdateTenantUserLicenseRequestModel
            {
                LicensePlan = newPlan,
                IsActive = user.IsActive
            });

            FlashMessage = "User plan updated successfully.";
            SelectedTenantUsers = (await PlatformAdminApiClient.GetTenantUsersAsync(OwnerSessionState, SelectedTenant.Id)).ToList();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsBusy = false;
        }
    }
