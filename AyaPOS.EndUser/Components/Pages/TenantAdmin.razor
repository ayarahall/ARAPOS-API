@page "/tenant-admin"
@rendermode InteractiveServer
@using Ayapos.EndUser.Models.Owner
@using Ayapos.EndUser.Models.Products
@using Ayapos.EndUser.Models.Staff
@using Ayapos.EndUser.Models.Services
@using Microsoft.AspNetCore.Components.Forms
@using Ayapos.EndUser.Services.Auth
@using Ayapos.EndUser.Services.TenantAdmin
@using Ayapos.EndUser.Services.Ui
@inject NavigationManager NavigationManager
@inject SessionState SessionState
@inject TenantAdminApiClient TenantAdminApiClient
@inject UiLanguageState UiLanguage

<PageTitle>@UiLanguage.Text("Tenant Admin", "إدارة التنت")</PageTitle>

<div class="products-page">
    <header class="products-header">
        <div>
            <span class="eyebrow">@UiLanguage.Text("Tenant Admin", "إدارة التنت")</span>
            <h1>@UiLanguage.Text("Branches, branch users, and daily tenant operations", "الفروع، مستخدمو الفروع، والعمليات اليومية للتنت")</h1>
            <p>@UiLanguage.Text("Manage the current tenant branches and branch-level users without opening the platform owner console.", "أدر فروع التنت الحالية ومستخدمي مستوى الفرع بدون الحاجة لفتح لوحة المالك.")</p>
        </div>

        <UserAccessCard ScopeLabel="@UiLanguage.Text("Tenant Admin", "إدارة التنت")"
                        TenantLabel="@(TenantSummary?.Name ?? SessionState.TenantSlug)"
                        UserName="@SessionState.Username"
                        RoleLabel="@UiLanguage.Text("Tenant Admin", "مدير التنت")"
                        LogoutText="@UiLanguage.Text("Sign Out", "تسجيل الخروج")"
                        OnLogout="SignOutAsync" />
    </header>

    <NotificationPopup SuccessMessage="@FlashMessage" ErrorMessage="@ErrorMessage" />

    @if (TenantSummary is not null)
    {
        <section class="metrics-grid">
            <article class="metric-card">
                <span class="metric-label">@UiLanguage.Text("Tenant", "التنت")</span>
                <strong class="metric-value">@TenantSummary.Name</strong>
                <span class="metric-note">@TenantSummary.Slug</span>
            </article>

            <article class="metric-card">
                <span class="metric-label">@UiLanguage.Text("Licensed Seats", "المقاعد المرخصة")</span>
                <strong class="metric-value">@TenantSummary.MaxUsers</strong>
                <span class="metric-note">@UiLanguage.Text("Maximum users allowed under this tenant license.", "أقصى عدد مستخدمين مسموح به تحت رخصة هذا التنت.")</span>
            </article>

            <article class="metric-card">
                <span class="metric-label">@UiLanguage.Text("Assigned Users", "المستخدمون المعينون")</span>
                <strong class="metric-value">@TenantSummary.AssignedUsers</strong>
                <span class="metric-note">@UiLanguage.Text("Users already assigned under this tenant.", "المستخدمون المعينون حاليًا تحت هذا التنت.")</span>
            </article>

            <article class="metric-card accent">
                <span class="metric-label">@UiLanguage.Text("License", "الرخصة")</span>
                <strong class="metric-value">@TenantSummary.LicensePlan</strong>
                <span class="metric-note">@UiLanguage.Text("Status", "الحالة"): @TenantSummary.LicenseStatus @UiLanguage.Text("until", "حتى") @TenantSummary.LicenseExpiresAt.ToLocalTime().ToString("yyyy-MM-dd")</span>
            </article>
        </section>
    }

    <section class="showcase-panel">
        <div class="showcase-header">
            <div>
                <span class="eyebrow">@UiLanguage.Text("Create Branch", "إنشاء فرع")</span>
                <h2>@UiLanguage.Text("Add a branch under this tenant", "إضافة فرع تحت هذا التنت")</h2>
            </div>
            <p>@UiLanguage.Text("Create an operational branch workspace. Each branch is provisioned with its own POS invoice sequence, appointments scope, print settings, and later can carry users, expenses, and day-to-day branch activity.", "أنشئ مساحة عمل تشغيلية للفرع. كل فرع يملك تسلسل فواتير POS خاصًا به ونطاق مواعيد وإعدادات طباعة، ويمكنه لاحقًا حمل المستخدمين والمصروفات والنشاط اليومي.")</p>
        </div>

        <div class="invoice-form-grid" style="margin-top:18px;">
                <div class="field">
                <label for="tenantBranchName">@UiLanguage.Text("Branch Name", "اسم الفرع")</label>
                <input id="tenantBranchName" class="form-input" @bind="CreateBranchModel.Name" />
            </div>

            <div class="field">
                <label for="tenantBranchCode">@UiLanguage.Text("Branch Code", "كود الفرع")</label>
                <input id="tenantBranchCode" class="form-input" @bind="CreateBranchModel.Code" />
            </div>

            <div class="field">
                <label for="tenantBranchCurrency">@UiLanguage.Text("Currency", "العملة")</label>
                <input id="tenantBranchCurrency" class="form-input" @bind="CreateBranchModel.CurrencyCode" />
            </div>
        </div>

        <div class="invoice-actions" style="margin-top:16px;">
            <button class="submit-button" @onclick="CreateBranchAsync" disabled="@IsBusy">@UiLanguage.Text("Create Branch", "إنشاء الفرع")</button>
            <button class="ghost-button" @onclick="RefreshDashboardAsync" disabled="@IsBusy">@UiLanguage.Text("Refresh Dashboard", "تحديث اللوحة")</button>
        </div>
    </section>

    <section class="products-table-wrap">
        @if (Branches.Count == 0)
        {
            <div class="placeholder-panel" style="margin-top:20px;">@UiLanguage.Text("No branches loaded for this tenant yet.", "لا توجد فروع محملة لهذا التنت حتى الآن.")</div>
        }
        else
        {
            <table class="products-table">
                <thead>
                            <tr>
                                <th>@UiLanguage.Text("Branch", "الفرع")</th>
                                <th>@UiLanguage.Text("Currency", "العملة")</th>
                                <th>@UiLanguage.Text("Branch Workspaces", "مساحات الفرع")</th>
                                <th>@UiLanguage.Text("Next POS No.", "رقم POS التالي")</th>
                                <th>@UiLanguage.Text("Status", "الحالة")</th>
                                <th>@UiLanguage.Text("Assigned Users", "المستخدمون المعينون")</th>
                                <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var branch in Branches)
                    {
                        <tr>
                            <td>
                                <div class="table-primary-cell">@branch.Name</div>
                                <div class="table-secondary-cell">@branch.Code</div>
                            </td>
                            <td>@branch.CurrencyCode</td>
                            <td>
                                <div class="table-primary-cell">@BuildBranchWorkspacesLabel(branch)</div>
                                <div class="table-secondary-cell">POS / Appointments / Expenses / Print</div>
                            </td>
                            <td>@branch.NextInvoiceNumber</td>
                            <td>@(branch.IsActive ? "Active" : "Inactive")</td>
                            <td>@branch.AssignedUsers</td>
                            <td>
                                <button class="ghost-button" @onclick="() => SelectBranchAsync(branch)">Manage Branch</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>

    @if (SelectedBranch is not null)
    {
        <nav class="section-tabs" aria-label="Selected branch admin sections">
            <button type="button" class="@GetBranchAdminTabClass("workspace")" @onclick="SelectWorkspaceTab">@UiLanguage.Text("Workspace", "مساحة العمل")</button>
            <button type="button" class="@GetBranchAdminTabClass("users")" @onclick="SelectUsersTab">@UiLanguage.Text("Users", "المستخدمون")</button>
            <button type="button" class="@GetBranchAdminTabClass("employees")" @onclick="SelectEmployeesTab">@UiLanguage.Text("Employees", "الموظفون")</button>
            <button type="button" class="@GetBranchAdminTabClass("products")" @onclick="SelectProductsTab">@UiLanguage.Text("Products", "المنتجات")</button>
            <button type="button" class="@GetBranchAdminTabClass("services")" @onclick="SelectServicesTab">@UiLanguage.Text("Services", "الخدمات")</button>
        </nav>

        @if (SelectedBranchAdminTab == "workspace")
        {
        <section class="showcase-panel">
            <div class="showcase-header">
                <div>
                    <span class="eyebrow">@UiLanguage.Text("Branch Settings", "إعدادات الفرع")</span>
                    <h2>@SelectedBranch.Name</h2>
                </div>
                <p>@UiLanguage.Text("Update branch details and control whether the branch is active for future operations.", "حدّث بيانات الفرع وتحكّم فيما إذا كان الفرع فعالاً للعمليات القادمة.")</p>
            </div>

            <section class="metrics-grid" style="margin-top:18px;">
                <article class="metric-card">
                    <span class="metric-label">@UiLanguage.Text("Branch Code", "كود الفرع")</span>
                    <strong class="metric-value">@SelectedBranch.Code</strong>
                    <span class="metric-note">@UiLanguage.Text("Current branch identifier inside this tenant.", "المعرّف الحالي للفرع داخل هذا التنت.")</span>
                </article>

                <article class="metric-card">
                    <span class="metric-label">@UiLanguage.Text("Assigned Users", "المستخدمون المعيّنون")</span>
                    <strong class="metric-value">@BranchUsers.Count</strong>
                    <span class="metric-note">@UiLanguage.Text("All active and inactive users assigned under this branch.", "جميع المستخدمين النشطين وغير النشطين المعيّنين تحت هذا الفرع.")</span>
                </article>

                <article class="metric-card">
                    <span class="metric-label">@UiLanguage.Text("Branch Workspaces", "مساحات عمل الفرع")</span>
                    <strong class="metric-value">@BuildBranchWorkspacesLabel(SelectedBranch)</strong>
                    <span class="metric-note">@UiLanguage.Text("Appointments, POS, expenses, and receipt settings stay scoped to this branch.", "المواعيد ونقطة البيع والمصروفات وإعدادات الإيصال تبقى ضمن نطاق هذا الفرع.")</span>
                </article>

                <article class="metric-card">
                    <span class="metric-label">@UiLanguage.Text("Role Mix", "توزيع الأدوار")</span>
                    <strong class="metric-value">@($"{CashierCount} / {HrCount} / {BranchManagerCount}")</strong>
                    <span class="metric-note">@UiLanguage.Text("Cashier / HR / Branch Manager distribution for the selected branch.", "توزيع الكاشير / الموارد البشرية / مدير الفرع للفرع المحدد.")</span>
                </article>

                <article class="metric-card accent">
                    <span class="metric-label">@UiLanguage.Text("Branch Status", "حالة الفرع")</span>
                    <strong class="metric-value">@(SelectedBranch.IsActive ? UiLanguage.Text("Active", "نشط") : UiLanguage.Text("Inactive", "غير نشط"))</strong>
                    <span class="metric-note">@UiLanguage.Text("Currency", "العملة"): @SelectedBranch.CurrencyCode | @UiLanguage.Text("Next POS No.", "رقم POS التالي"): @SelectedBranch.NextInvoiceNumber</span>
                </article>
            </section>

            <div class="invoice-form-grid" style="margin-top:18px;">
                <div class="field">
                    <label for="selectedTenantBranchName">@UiLanguage.Text("Branch Name", "اسم الفرع")</label>
                    <input id="selectedTenantBranchName" class="form-input" @bind="UpdateBranchModel.Name" />
                </div>

                <div class="field">
                    <label for="selectedTenantBranchCode">@UiLanguage.Text("Branch Code", "كود الفرع")</label>
                    <input id="selectedTenantBranchCode" class="form-input" @bind="UpdateBranchModel.Code" />
                </div>

                <div class="field">
                    <label for="selectedTenantBranchCurrency">@UiLanguage.Text("Currency", "العملة")</label>
                    <input id="selectedTenantBranchCurrency" class="form-input" @bind="UpdateBranchModel.CurrencyCode" />
                </div>

                <div class="field">
                    <label for="selectedTenantBranchStatus">@UiLanguage.Text("Status", "الحالة")</label>
                    <select id="selectedTenantBranchStatus" class="form-input" @bind="SelectedBranchStatusValue">
                        <option value="true">@UiLanguage.Text("Active", "نشط")</option>
                        <option value="false">@UiLanguage.Text("Inactive", "غير نشط")</option>
                    </select>
                </div>
            </div>

            <div class="invoice-actions" style="margin-top:16px;">
                <button class="submit-button" @onclick="UpdateBranchAsync" disabled="@IsBusy">@UiLanguage.Text("Update Branch", "تحديث الفرع")</button>
                <button class="ghost-button" @onclick="RefreshSelectedBranchAsync" disabled="@IsBusy">@UiLanguage.Text("Refresh Branch", "تحديث بيانات الفرع")</button>
                <button class="ghost-button" @onclick="ClearSelectedBranch">@UiLanguage.Text("Close Branch Panel", "إغلاق لوحة الفرع")</button>
            </div>
        </section>

        <section class="showcase-panel">
            <div class="showcase-header">
                <div>
                    <span class="eyebrow">@UiLanguage.Text("Invoice Print", "طباعة الفاتورة")</span>
                    <h2>@UiLanguage.Text("Customer receipt settings", "إعدادات إيصال العميل")</h2>
                </div>
                <p>@UiLanguage.Text("Control how the printed customer invoice looks for this branch, including title, header, footer, and auto-print behavior.", "تحكّم في شكل فاتورة العميل المطبوعة لهذا الفرع، بما يشمل العنوان والرأس والتذييل وسلوك الطباعة التلقائية.")</p>
            </div>

            <div class="invoice-form-grid" style="margin-top:18px;">
                <div class="field">
                    <label for="branchCompanyName">@UiLanguage.Text("Company Name", "اسم الشركة")</label>
                    <input id="branchCompanyName" class="form-input" @bind="BranchPrintSettings.CompanyName" />
                </div>

                <div class="field">
                    <label for="branchCompanyLogoUrl">@UiLanguage.Text("Logo URL", "رابط اللوجو")</label>
                    <input id="branchCompanyLogoUrl" class="form-input" @bind="BranchPrintSettings.CompanyLogoUrl" placeholder="https://..." />
                </div>

                <div class="field">
                    <label for="branchCompanyPhone">@UiLanguage.Text("Phone", "الهاتف")</label>
                    <input id="branchCompanyPhone" class="form-input" @bind="BranchPrintSettings.CompanyPhone" />
                </div>

                <div class="field">
                    <label for="branchCompanyAddress">@UiLanguage.Text("Address", "العنوان")</label>
                    <input id="branchCompanyAddress" class="form-input" @bind="BranchPrintSettings.CompanyAddress" />
                </div>

                <div class="field">
                    <label for="branchCompanyTaxNumber">@UiLanguage.Text("Tax Number", "الرقم الضريبي")</label>
                    <input id="branchCompanyTaxNumber" class="form-input" @bind="BranchPrintSettings.CompanyTaxNumber" />
                </div>

                <div class="field">
                    <label for="branchReceiptTitle">@UiLanguage.Text("Receipt Title", "عنوان الإيصال")</label>
                    <input id="branchReceiptTitle" class="form-input" @bind="BranchPrintSettings.ReceiptTitle" />
                </div>

                <div class="field">
                    <label for="branchReceiptHeader1">@UiLanguage.Text("Header Line 1", "السطر الأول في الرأس")</label>
                    <input id="branchReceiptHeader1" class="form-input" @bind="BranchPrintSettings.ReceiptHeaderLine1" />
                </div>

                <div class="field">
                    <label for="branchReceiptHeader2">@UiLanguage.Text("Header Line 2", "السطر الثاني في الرأس")</label>
                    <input id="branchReceiptHeader2" class="form-input" @bind="BranchPrintSettings.ReceiptHeaderLine2" />
                </div>

                <div class="field">
                    <label for="branchReceiptFooter">@UiLanguage.Text("Footer Note", "ملاحظة التذييل")</label>
                    <input id="branchReceiptFooter" class="form-input" @bind="BranchPrintSettings.ReceiptFooterNote" />
                </div>
            </div>

            <div class="metrics-grid" style="margin-top:18px;">
                <article class="metric-card">
                    <span class="metric-label">@UiLanguage.Text("Show Branch Name", "إظهار اسم الفرع")</span>
                    <strong class="metric-value">@(BranchPrintSettings.ShowBranchNameOnReceipt ? UiLanguage.Text("Yes", "نعم") : UiLanguage.Text("No", "لا"))</strong>
                    <div style="margin-top:8px;">
                        <input id="showBranchNameOnReceipt" type="checkbox" @bind="BranchPrintSettings.ShowBranchNameOnReceipt" />
                        <label for="showBranchNameOnReceipt" style="margin-left:8px;">@UiLanguage.Text("Include branch name on the printed receipt", "تضمين اسم الفرع في الإيصال المطبوع")</label>
                    </div>
                </article>

                <article class="metric-card">
                    <span class="metric-label">@UiLanguage.Text("Show Customer Name", "إظهار اسم العميل")</span>
                    <strong class="metric-value">@(BranchPrintSettings.ShowCustomerNameOnReceipt ? UiLanguage.Text("Yes", "نعم") : UiLanguage.Text("No", "لا"))</strong>
                    <div style="margin-top:8px;">
                        <input id="showCustomerNameOnReceipt" type="checkbox" @bind="BranchPrintSettings.ShowCustomerNameOnReceipt" />
                        <label for="showCustomerNameOnReceipt" style="margin-left:8px;">@UiLanguage.Text("Include customer name on the printed receipt", "تضمين اسم العميل في الإيصال المطبوع")</label>
                    </div>
                </article>

                <article class="metric-card">
                    <span class="metric-label">@UiLanguage.Text("Show Payment History", "إظهار سجل الدفعات")</span>
                    <strong class="metric-value">@(BranchPrintSettings.ShowPaymentHistoryOnReceipt ? UiLanguage.Text("Yes", "نعم") : UiLanguage.Text("No", "لا"))</strong>
                    <div style="margin-top:8px;">
                        <input id="showPaymentHistoryOnReceipt" type="checkbox" @bind="BranchPrintSettings.ShowPaymentHistoryOnReceipt" />
                        <label for="showPaymentHistoryOnReceipt" style="margin-left:8px;">@UiLanguage.Text("Include recorded payments in the receipt view", "تضمين الدفعات المسجلة داخل الإيصال")</label>
                    </div>
                </article>

                <article class="metric-card accent">
                    <span class="metric-label">@UiLanguage.Text("Auto Print After Payment", "الطباعة التلقائية بعد الدفع")</span>
                    <strong class="metric-value">@(BranchPrintSettings.AutoPrintReceiptAfterPayment ? UiLanguage.Text("Enabled", "مفعّل") : UiLanguage.Text("Manual", "يدوي"))</strong>
                    <div style="margin-top:8px;">
                        <input id="autoPrintReceiptAfterPayment" type="checkbox" @bind="BranchPrintSettings.AutoPrintReceiptAfterPayment" />
                        <label for="autoPrintReceiptAfterPayment" style="margin-left:8px;">@UiLanguage.Text("Open print dialog automatically after recording a payment", "فتح نافذة الطباعة تلقائياً بعد تسجيل دفعة")</label>
                    </div>
                </article>
            </div>

            <div class="invoice-actions" style="margin-top:16px;">
                <button class="submit-button" @onclick="SaveBranchPrintSettingsAsync" disabled="@IsBusy">@UiLanguage.Text("Save Print Settings", "حفظ إعدادات الطباعة")</button>
            </div>
        </section>
        }

        @if (SelectedBranchAdminTab == "products")
        {
        <section class="showcase-panel">
            <div class="showcase-header">
                <div>
                    <span class="eyebrow">@UiLanguage.Text("Branch Products", "منتجات الفرع")</span>
                    <h2>@UiLanguage.Text("Manage products for", "إدارة المنتجات للفرع") @SelectedBranch.Name</h2>
                </div>
                <p>@UiLanguage.Text("Products are created and maintained here at tenant level. Cashier and branch users will only browse and sell them.", "يتم إنشاء المنتجات وإدارتها هنا على مستوى التنت. أما مستخدمو الفرع والكاشير فسيقتصر دورهم على التصفح والبيع فقط.")</p>
            </div>

            <div class="invoice-form-grid" style="margin-top:18px;">
                <div class="field">
                    <label for="tenantBranchProductNameEn">@UiLanguage.Text("English Name", "الاسم بالإنجليزية")</label>
                    <input id="tenantBranchProductNameEn" class="form-input" @bind="CreateProductModel.NameEn" />
                </div>

                <div class="field">
                    <label for="tenantBranchProductNameAr">@UiLanguage.Text("Arabic Name", "الاسم بالعربية")</label>
                    <input id="tenantBranchProductNameAr" class="form-input" @bind="CreateProductModel.NameAr" />
                </div>

                <div class="field">
                    <label for="tenantBranchProductSku">SKU</label>
                    <input id="tenantBranchProductSku" class="form-input" @bind="CreateProductModel.Sku" />
                </div>

                <div class="field">
                    <label for="tenantBranchProductBarcode">@UiLanguage.Text("Barcode", "الباركود")</label>
                    <input id="tenantBranchProductBarcode" class="form-input" @bind="CreateProductModel.Barcode" />
                </div>

                <div class="field">
                    <label for="tenantBranchProductPrice">@UiLanguage.Text("Sell Price", "سعر البيع")</label>
                    <input id="tenantBranchProductPrice" class="form-input" type="number" step="0.01" min="0" @bind="CreateProductModel.SellPrice" />
                </div>

                <div class="field">
                    <label for="tenantBranchProductCurrency">@UiLanguage.Text("Currency", "العملة")</label>
                    <input id="tenantBranchProductCurrency" class="form-input" @bind="CreateProductModel.CurrencyCode" />
                </div>

                <div class="field">
                    <label for="tenantBranchProductUnit">@UiLanguage.Text("Unit", "الوحدة")</label>
                    <input id="tenantBranchProductUnit" class="form-input" @bind="CreateProductModel.Unit" />
                </div>

                <div class="field">
                    <label for="tenantBranchProductStatus">@UiLanguage.Text("Status", "الحالة")</label>
                    <select id="tenantBranchProductStatus" class="form-input" @bind="CreateProductStatusValue">
                        <option value="true">@UiLanguage.Text("Active", "نشط")</option>
                        <option value="false">@UiLanguage.Text("Inactive", "غير نشط")</option>
                    </select>
                </div>
            </div>

            <div class="invoice-actions" style="margin-top:16px;">
                <button class="submit-button" @onclick="CreateBranchProductAsync" disabled="@IsBusy">@UiLanguage.Text("Create Product", "إنشاء منتج")</button>
                <button class="ghost-button" @onclick="RefreshBranchCatalogAsync" disabled="@IsBusy">@UiLanguage.Text("Refresh Catalog", "تحديث الكتالوج")</button>
            </div>

            <div class="products-table-wrap" style="margin-top:20px;">
                @if (BranchProducts.Count == 0)
                {
                    <div class="placeholder-panel">@UiLanguage.Text("No products loaded for this branch yet.", "لا توجد منتجات محملة لهذا الفرع حتى الآن.")</div>
                }
                else
                {
                    <table class="products-table">
                        <thead>
                            <tr>
                                <th>@UiLanguage.Text("Product", "المنتج")</th>
                                <th>SKU</th>
                                <th>@UiLanguage.Text("Price", "السعر")</th>
                                <th>@UiLanguage.Text("Status", "الحالة")</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var product in BranchProducts)
                            {
                                <tr>
                                    <td>
                                        <div class="table-primary-cell">@GetProductDisplayName(product)</div>
                                        <div class="table-secondary-cell">@(string.IsNullOrWhiteSpace(product.Barcode) ? UiLanguage.Text("No barcode", "لا يوجد باركود") : product.Barcode)</div>
                                    </td>
                                    <td>@(string.IsNullOrWhiteSpace(product.Sku) ? "-" : product.Sku)</td>
                                    <td>@FormatProductPrice(product)</td>
                                    <td>@(product.IsActive ? UiLanguage.Text("Active", "نشط") : UiLanguage.Text("Inactive", "غير نشط"))</td>
                                    <td><button class="ghost-button" @onclick="() => SelectProduct(product)">@UiLanguage.Text("Manage", "إدارة")</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </section>
        }

        @if (SelectedBranchAdminTab == "products" && SelectedProduct is not null)
        {
            <section class="showcase-panel">
                <div class="showcase-header">
                    <div>
                        <span class="eyebrow">@UiLanguage.Text("Selected Product", "المنتج المحدد")</span>
                        <h2>@GetProductDisplayName(SelectedProduct)</h2>
                    </div>
