            await LoadSelectedEmployeeWorkspaceAsync();
            FlashMessage = "Employee checked out successfully.";
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsBusy = false;
        }
    }

