                    <strong class="metric-value">@($"{AttendanceSummary.TotalDeductions:0.##} AED")</strong>
                    <span class="metric-note">@UiLanguage.Text("Late and absent deductions already calculated today.", "تم احتساب خصومات التأخير والغياب لليوم بالفعل.")</span>
                </article>
            </section>

            <div class="invoice-form-grid" style="margin-top:18px;">
                <div class="field">
                    <label for="employeeFullName">@UiLanguage.Text("Full Name", "الاسم الكامل")</label>
                    <input id="employeeFullName" class="form-input" @bind="CreateEmployeeModel.FullName" />
                </div>

                <div class="field">
                    <label for="employeeCode">@UiLanguage.Text("Employee Code", "كود الموظف")</label>
                    <input id="employeeCode" class="form-input" @bind="CreateEmployeeModel.EmployeeCode" />
                </div>

                <div class="field">
                    <label for="employeePhone">@UiLanguage.Text("Phone", "الهاتف")</label>
                    <input id="employeePhone" class="form-input" @bind="CreateEmployeeModel.Phone" />
                </div>

                <div class="field">
                    <label for="employeeJobTitle">@UiLanguage.Text("Job Title", "المسمى الوظيفي")</label>
                    <input id="employeeJobTitle" class="form-input" @bind="CreateEmployeeModel.JobTitle" />
                </div>

                <div class="field">
                    <label for="employeeSalary">@UiLanguage.Text("Base Salary", "الراتب الأساسي")</label>
                    <input id="employeeSalary" class="form-input" type="number" step="0.01" min="0" @bind="CreateEmployeeModel.BaseSalary" />
                </div>

                <div class="field">
                    <label for="employeeLinkedUser">@UiLanguage.Text("Linked System User", "مستخدم النظام المرتبط")</label>
                    <select id="employeeLinkedUser" class="form-input" @bind="CreateEmployeeLinkedUserIdValue">
                        <option value="">@UiLanguage.Text("No system access", "بدون وصول للنظام")</option>
                        @foreach (var branchUser in BranchUsers)
                        {
                            <option value="@branchUser.Id.ToString()">@branchUser.Username (@branchUser.Role)</option>
                        }
                    </select>
                </div>
            </div>

            <div class="invoice-form-grid" style="margin-top:16px;">
                <div class="field">
                    <label for="employeeLateDeduction">@UiLanguage.Text("Deduction Per Late Minute", "خصم كل دقيقة تأخير")</label>
                    <input id="employeeLateDeduction" class="form-input" type="number" step="0.01" min="0" @bind="CreateEmployeeModel.DeductionPerLateMinute" />
                </div>

                <div class="field">
                    <label for="employeeAbsentDeduction">@UiLanguage.Text("Deduction Per Absent Day", "خصم كل يوم غياب")</label>
                    <input id="employeeAbsentDeduction" class="form-input" type="number" step="0.01" min="0" @bind="CreateEmployeeModel.DeductionPerAbsentDay" />
                </div>

                <div class="field">
                    <label for="employeeWeeklyOff">@UiLanguage.Text("Weekly Off Days", "أيام العطلة الأسبوعية")</label>
                    <input id="employeeWeeklyOff" class="form-input" placeholder="@UiLanguage.Text("Sunday, Monday", "الأحد، الاثنين")" @bind="CreateEmployeeModel.WeeklyOffDays" />
                </div>

                <div class="field">
                    <label for="employeeHireDate">@UiLanguage.Text("Hire Date", "تاريخ التوظيف")</label>
                    <input id="employeeHireDate" class="form-input" type="date" @bind="CreateEmployeeHireDateValue" />
