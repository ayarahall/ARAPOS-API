    private static string GetProductDisplayName(ProductListItemModel product)
        => !string.IsNullOrWhiteSpace(product.NameEn)
            ? product.NameEn
            : !string.IsNullOrWhiteSpace(product.NameAr)
                ? product.NameAr
                : "Unnamed product";

    private static Guid? ParseNullableGuid(string? value)
        => Guid.TryParse(value, out var parsed) ? parsed : null;

    private static TimeSpan ParseTime(string? value)
        => TimeSpan.TryParse(value, out var parsed) ? parsed : TimeSpan.Zero;

    private static string FormatMoney(decimal? amount)
        => amount.HasValue ? $"{amount.Value:0.##} AED" : "Salary pending";

    private static string MapAttendanceStatus(string? status)
        => string.IsNullOrWhiteSpace(status) ? "No record"
            : status.Equals("present", StringComparison.OrdinalIgnoreCase) ? "Present"
            : status.Equals("late", StringComparison.OrdinalIgnoreCase) ? "Late"
            : status.Equals("absent", StringComparison.OrdinalIgnoreCase) ? "Absent"
            : status.Equals("leave", StringComparison.OrdinalIgnoreCase) ? "Leave"
            : status.Equals("off", StringComparison.OrdinalIgnoreCase) ? "Weekly Off"
            : status;

    private static string FormatDateTime(DateTime? value)
        => value.HasValue ? value.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : "-";

    private static string FormatProductPrice(ProductListItemModel product)
        => product.SellPrice is null ? "Price pending" : $"{product.SellPrice:0.##} {product.CurrencyCode}";

    private static string GetServiceDisplayName(ServiceListItemModel service)
        => !string.IsNullOrWhiteSpace(service.NameEn)
            ? service.NameEn
            : !string.IsNullOrWhiteSpace(service.NameAr)
                ? service.NameAr
                : "Unnamed service";

    private static string FormatServicePrice(ServiceListItemModel service)
        => $"{service.Price:0.##} {service.CurrencyCode}";

    private static string FormatServiceDuration(int? durationMin)
        => durationMin is null || durationMin <= 0 ? "Duration pending" : $"{durationMin.Value} min";

    private static string BuildBranchWorkspacesLabel(PlatformBranchModel branch)
    {
        var enabled = 0;
        if (branch.HasPosWorkspace) enabled++;
        if (branch.HasAppointmentsWorkspace) enabled++;
        if (branch.HasExpensesWorkspace) enabled++;
        if (branch.HasPrintSettings) enabled++;
        return $"{enabled}/4 Ready";
    }
}
