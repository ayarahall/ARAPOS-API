        <section class="products-table-wrap">
            @if (BranchEmployees.Count == 0)
            {
                <div class="placeholder-panel" style="margin-top:20px;">@UiLanguage.Text("No employees loaded for this branch yet.", "لا يوجد موظفون محملون لهذا الفرع حتى الآن.")</div>
