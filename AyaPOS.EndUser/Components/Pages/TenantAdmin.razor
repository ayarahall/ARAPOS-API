                </div>

                <div class="invoice-form-grid" style="margin-top:18px;">
                    <div class="field">
                        <label for="selectedEmployeeName">Full Name</label>
                        <input id="selectedEmployeeName" class="form-input" @bind="UpdateEmployeeModel.FullName" />
                    </div>

                    <div class="field">
                        <label for="selectedEmployeePhone">Phone</label>
                        <input id="selectedEmployeePhone" class="form-input" @bind="UpdateEmployeeModel.Phone" />
                    </div>

                    <div class="field">
                        <label for="selectedEmployeeJob">Job Title</label>
                        <input id="selectedEmployeeJob" class="form-input" @bind="UpdateEmployeeModel.JobTitle" />
                    </div>

                    <div class="field">
                        <label for="selectedEmployeeLinkedUser">Linked System User</label>
                        <select id="selectedEmployeeLinkedUser" class="form-input" @bind="SelectedEmployeeLinkedUserIdValue">
                            <option value="">No system access</option>
                            @foreach (var branchUser in BranchUsers)
                            {
                                <option value="@branchUser.Id.ToString()">@branchUser.Username (@branchUser.Role)</option>
                            }
                        </select>
                    </div>

                    <div class="field">
                        <label for="selectedEmployeeBaseSalary">Base Salary</label>
                        <input id="selectedEmployeeBaseSalary" class="form-input" type="number" step="0.01" min="0" @bind="UpdateEmployeeModel.BaseSalary" />
                    </div>

                    <div class="field">
                        <label for="selectedEmployeeLateDeduction">Deduction Per Late Minute</label>
                        <input id="selectedEmployeeLateDeduction" class="form-input" type="number" step="0.01" min="0" @bind="UpdateEmployeeModel.DeductionPerLateMinute" />
                    </div>
                </div>

                <div class="invoice-actions" style="margin-top:16px;">
                    <button class="submit-button" @onclick="UpdateBranchEmployeeAsync" disabled="@IsBusy">Save Employee</button>
                    <button class="ghost-button" @onclick="CheckInSelectedEmployeeAsync" disabled="@IsBusy">Check In</button>
                    <button class="ghost-button" @onclick="CheckOutSelectedEmployeeAsync" disabled="@IsBusy">Check Out</button>
                    <button class="ghost-button" @onclick="MarkSelectedEmployeeAttendanceAsync" disabled="@IsBusy">Mark Attendance</button>
                    <button class="ghost-button" @onclick="ClearSelectedEmployee">Close Employee Panel</button>
                </div>

                <div class="invoice-form-grid" style="margin-top:18px;">
                    <div class="field">
                        <label for="selectedAttendanceDate">Attendance Date</label>
                        <input id="selectedAttendanceDate" class="form-input" type="date" @bind="AttendanceMarkDateValue" />
                    </div>

                    <div class="field">
                        <label for="selectedAttendanceStatus">Manual Status</label>
                        <select id="selectedAttendanceStatus" class="form-input" @bind="AttendanceMarkStatus">
                            <option value="present">Present</option>
                            <option value="late">Late</option>
                            <option value="absent">Absent</option>
                            <option value="leave">Leave</option>
                            <option value="off">Weekly Off</option>
                        </select>
                    </div>

                    <div class="field">
                        <label for="selectedAttendanceNotes">Notes</label>
                        <input id="selectedAttendanceNotes" class="form-input" @bind="AttendanceMarkNotes" />
                    </div>
                </div>

                <div class="products-table-wrap" style="margin-top:20px;">
                    @if (SelectedEmployeeAttendance.Count == 0)
                    {
                        <div class="placeholder-panel">No attendance records loaded yet.</div>
                    }
                    else
                    {
                        <table class="products-table">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Status</th>
                                    <th>Check In</th>
                                    <th>Check Out</th>
                                    <th>Late</th>
                                    <th>Worked</th>
                                    <th>Deduction</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in SelectedEmployeeAttendance)
                                {
                                    <tr>
                                        <td>@item.AttendanceDate.ToString("yyyy-MM-dd")</td>
                                        <td>@MapAttendanceStatus(item.Status)</td>
                                        <td>@FormatDateTime(item.CheckInAt)</td>
                                        <td>@FormatDateTime(item.CheckOutAt)</td>
                                        <td>@($"{item.LateMinutes} min")</td>
                                        <td>@($"{item.WorkedMinutes} min")</td>
                                        <td>@($"{item.DeductionAmount:0.##} AED")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>

                <div class="invoice-form-grid" style="margin-top:20px;">
                    <div class="field">
                        <label for="employeeShiftNameCreate">Shift Name</label>
                        <input id="employeeShiftNameCreate" class="form-input" @bind="CreateEmployeeShiftModel.Name" />
                    </div>

                    <div class="field">
                        <label for="employeeShiftStartCreate">Start Time</label>
                        <input id="employeeShiftStartCreate" class="form-input" @bind="CreateEmployeeShiftStartValue" />
                    </div>

                    <div class="field">
                        <label for="employeeShiftEndCreate">End Time</label>
                        <input id="employeeShiftEndCreate" class="form-input" @bind="CreateEmployeeShiftEndValue" />
                    </div>

                    <div class="field">
                        <label for="employeeShiftGraceCreate">Grace Minutes</label>
                        <input id="employeeShiftGraceCreate" class="form-input" type="number" min="0" @bind="CreateEmployeeShiftModel.GraceMinutes" />
                    </div>
                </div>

                <div class="invoice-actions" style="margin-top:16px;">
                    <button class="submit-button" @onclick="CreateSelectedEmployeeShiftAsync" disabled="@IsBusy">Create Shift</button>
                </div>

                <div class="products-table-wrap" style="margin-top:20px;">
                    @if (SelectedEmployeeShifts.Count == 0)
                    {
                        <div class="placeholder-panel">No shifts loaded yet.</div>
                    }
                    else
                    {
                        <table class="products-table">
                            <thead>
                                <tr>
                                    <th>Shift</th>
                                    <th>Time</th>
                                    <th>Grace</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var shift in SelectedEmployeeShifts)
                                {
                                    <tr>
                                        <td>@shift.Name</td>
                                        <td>@($"{shift.StartTime:hh\\:mm} - {shift.EndTime:hh\\:mm}")</td>
                                        <td>@($"{shift.GraceMinutes} min")</td>
                                        <td>@(shift.IsActive ? "Active" : "Inactive")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>

                <div class="invoice-form-grid" style="margin-top:20px;">
                    <div class="field">
                        <label for="employeeLeaveTypeCreate">Leave Type</label>
                        <select id="employeeLeaveTypeCreate" class="form-input" @bind="CreateEmployeeLeaveModel.LeaveType">
                            <option value="annual">Annual</option>
                            <option value="sick">Sick</option>
                            <option value="emergency">Emergency</option>
                            <option value="other">Other</option>
                        </select>
                    </div>

                    <div class="field">
                        <label for="employeeLeaveStartCreate">Start Date</label>
                        <input id="employeeLeaveStartCreate" class="form-input" type="date" @bind="CreateEmployeeLeaveStartValue" />
                    </div>

                    <div class="field">
                        <label for="employeeLeaveEndCreate">End Date</label>
                        <input id="employeeLeaveEndCreate" class="form-input" type="date" @bind="CreateEmployeeLeaveEndValue" />
                    </div>

                    <div class="field">
                        <label for="employeeDocumentTitleCreate">Document Title</label>
                        <input id="employeeDocumentTitleCreate" class="form-input" @bind="CreateEmployeeDocumentModel.Title" />
                    </div>
                </div>

                <div class="invoice-actions" style="margin-top:16px;">
                    <button class="submit-button" @onclick="CreateSelectedEmployeeLeaveAsync" disabled="@IsBusy">Create Leave</button>
                    <button class="ghost-button" @onclick="CreateSelectedEmployeeDocumentAsync" disabled="@IsBusy">Add Document</button>
                </div>
            </section>
        }
        }
    }
</div>

@code {
    private bool _sessionChecked;
    private bool IsBusy { get; set; }
    private bool IsImportingServices { get; set; }
    private string ErrorMessage { get; set; } = string.Empty;
    private string FlashMessage { get; set; } = string.Empty;
    private string ServiceImportStatusSummary { get; set; } = string.Empty;

    private PlatformTenantModel? TenantSummary { get; set; }
    private List<PlatformBranchModel> Branches { get; set; } = [];
    private PlatformBranchModel? SelectedBranch { get; set; }
    private string SelectedBranchAdminTab { get; set; } = "workspace";
    private List<PlatformBranchUserModel> BranchUsers { get; set; } = [];
    private PlatformBranchUserModel? SelectedBranchUser { get; set; }
    private bool ShowBranchUserModal { get; set; }
    private HashSet<string> SelectedBranchUserPermissionSelections { get; set; } = new(StringComparer.OrdinalIgnoreCase);
    private BranchInvoicePrintSettingsModel BranchPrintSettings { get; set; } = new();
    private List<ProductListItemModel> BranchProducts { get; set; } = [];
    private ProductListItemModel? SelectedProduct { get; set; }
    private CreateProductRequestModel CreateProductModel { get; set; } = new();
    private UpdateProductRequestModel UpdateProductModel { get; set; } = new();
    private string CreateProductStatusValue { get; set; } = "true";
    private string SelectedProductStatusValue { get; set; } = "true";
    private List<ServiceListItemModel> BranchServices { get; set; } = [];
    private ServiceListItemModel? SelectedService { get; set; }
    private CreateServiceRequestModel CreateServiceModel { get; set; } = new();
    private UpdateServiceRequestModel UpdateServiceModel { get; set; } = new();
    private string CreateServiceStatusValue { get; set; } = "true";
    private string SelectedServiceStatusValue { get; set; } = "true";
    private IBrowserFile? ServiceImportFile { get; set; }
    private string ServiceImportFileName { get; set; } = "No file selected.";
    private List<EmployeeListItemModel> BranchEmployees { get; set; } = [];
    private EmployeeListItemModel? SelectedEmployee { get; set; }
    private BranchAttendanceSummaryModel AttendanceSummary { get; set; } = new() { Date = DateTime.Today };
    private List<EmployeeAttendanceModel> SelectedEmployeeAttendance { get; set; } = [];
    private List<EmployeeShiftModel> SelectedEmployeeShifts { get; set; } = [];
    private List<EmployeeLeaveModel> SelectedEmployeeLeaves { get; set; } = [];
    private List<EmployeeDocumentModel> SelectedEmployeeDocuments { get; set; } = [];
    private CreateEmployeeRequestModel CreateEmployeeModel { get; set; } = new();
    private UpdateEmployeeRequestModel UpdateEmployeeModel { get; set; } = new();
    private CreateEmployeeShiftRequestModel CreateEmployeeShiftModel { get; set; } = new();
    private CreateEmployeeLeaveRequestModel CreateEmployeeLeaveModel { get; set; } = new();
    private CreateEmployeeDocumentRequestModel CreateEmployeeDocumentModel { get; set; } = new();
    private string CreateEmployeeLinkedUserIdValue { get; set; } = string.Empty;
    private string SelectedEmployeeLinkedUserIdValue { get; set; } = string.Empty;
    private DateTime? CreateEmployeeHireDateValue { get; set; }
    private DateTime? UpdateEmployeeHireDateValue { get; set; }
    private DateTime AttendanceMarkDateValue { get; set; } = DateTime.Today;
    private string AttendanceMarkStatus { get; set; } = "present";
    private string AttendanceMarkNotes { get; set; } = string.Empty;
    private string CreateEmployeeShiftStartValue { get; set; } = "09:00";
    private string CreateEmployeeShiftEndValue { get; set; } = "18:00";
    private DateTime? CreateEmployeeShiftEffectiveFromValue { get; set; } = DateTime.Today;
    private DateTime? CreateEmployeeLeaveStartValue { get; set; } = DateTime.Today;
    private DateTime? CreateEmployeeLeaveEndValue { get; set; } = DateTime.Today;
    private DateTime? CreateEmployeeDocumentExpiryValue { get; set; }

    private int CashierCount => BranchUsers.Count(user => string.Equals(user.Role, "CASHIER", StringComparison.OrdinalIgnoreCase));
    private int HrCount => BranchUsers.Count(user => string.Equals(user.Role, "HR", StringComparison.OrdinalIgnoreCase));
    private int BranchManagerCount => BranchUsers.Count(user => string.Equals(user.Role, "BRANCH_MANAGER", StringComparison.OrdinalIgnoreCase));

    private CreateBranchRequestModel CreateBranchModel { get; set; } = new();
    private UpdateBranchRequestModel UpdateBranchModel { get; set; } = new();
    private CreateBranchUserRequestModel CreateBranchUserModel { get; set; } = new();
    private SetUserPasswordRequestModel BranchUserPasswordModel { get; set; } = new();
    private string SelectedBranchStatusValue { get; set; } = "true";
    private static readonly IReadOnlyList<(string Key, string Label, string Description)> BranchUserPermissionOptions =
    [
        ("pos", "Point of Sale", "Open the live selling screen and build draft sales."),
        ("products", "Products", "View branch products and pricing."),
        ("services", "Services", "View branch services and sell service lines."),
        ("customers", "Customers", "Search, create, and attach customers."),
        ("appointments", "Appointments", "Open the appointment board and manage bookings."),
        ("employees", "Employees", "Access employee files, attendance, and shifts."),
        ("expenses", "Expenses", "Log and review branch operating expenses."),
        ("cashier", "Cashier Session", "Open and close cashier sessions."),
        ("invoices", "Invoices", "Review invoices and create invoice records."),
        ("reports", "Reports", "Reserved for future reporting screens.")
    ];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _sessionChecked)
            return;

        _sessionChecked = true;
        try
        {
            await SessionState.InitializeAsync();
            await UiLanguage.InitializeAsync();

            if (!SessionState.IsAuthenticated)
            {
                NavigationManager.NavigateTo("/");
                return;
            }

            if (!SessionState.IsTenantAdmin)
            {
                NavigationManager.NavigateTo("/products");
                return;
            }

            await LoadDashboardAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }

        StateHasChanged();
    }

    private async Task LoadDashboardAsync()
    {
        ErrorMessage = string.Empty;
        TenantSummary = await TenantAdminApiClient.GetTenantAsync(SessionState);
        Branches = (await TenantAdminApiClient.GetBranchesAsync(SessionState)).ToList();

        if (SelectedBranch is not null)
        {
            SelectedBranch = Branches.FirstOrDefault(x => x.Id == SelectedBranch.Id);
            if (SelectedBranch is not null)
            {
                UpdateBranchModel = new UpdateBranchRequestModel
                {
                    Name = SelectedBranch.Name,
                    Code = SelectedBranch.Code,
                    CurrencyCode = SelectedBranch.CurrencyCode,
                    IsActive = SelectedBranch.IsActive
                };
                SelectedBranchStatusValue = SelectedBranch.IsActive ? "true" : "false";

                BranchUsers = (await TenantAdminApiClient.GetBranchUsersAsync(SessionState, SelectedBranch.Id)).ToList();
                  BranchPrintSettings = await TenantAdminApiClient.GetBranchPrintSettingsAsync(SessionState, SelectedBranch.Id);
                  BranchProducts = (await TenantAdminApiClient.GetBranchProductsAsync(SessionState, SelectedBranch.Id, null, 1, 100)).Items.ToList();
                  BranchServices = (await TenantAdminApiClient.GetBranchServicesAsync(SessionState, SelectedBranch.Id, null, 1, 100)).Items.ToList();
                  BranchEmployees = (await TenantAdminApiClient.GetBranchEmployeesAsync(SessionState, SelectedBranch.Id)).ToList();
                  AttendanceSummary = await TenantAdminApiClient.GetBranchAttendanceSummaryAsync(SessionState, SelectedBranch.Id, DateTime.Today);
                  SelectedBranchUser = SelectedBranchUser is null
                      ? null
                      : BranchUsers.FirstOrDefault(x => x.Id == SelectedBranchUser.Id);
                  SelectedProduct = SelectedProduct is null ? null : BranchProducts.FirstOrDefault(x => x.Id == SelectedProduct.Id);
                  SelectedService = SelectedService is null ? null : BranchServices.FirstOrDefault(x => x.Id == SelectedService.Id);
                  if (SelectedEmployee is not null)
                  {
                      SelectedEmployee = BranchEmployees.FirstOrDefault(x => x.Id == SelectedEmployee.Id);
                      if (SelectedEmployee is not null)
                          await LoadSelectedEmployeeWorkspaceAsync();
                  }
              }
              else
              {
                  BranchUsers = [];
                  SelectedBranchUser = null;
                  BranchPrintSettings = new BranchInvoicePrintSettingsModel();
                  BranchProducts = [];
                  SelectedProduct = null;
                  BranchServices = [];
                  SelectedService = null;
                  BranchEmployees = [];
                  AttendanceSummary = new BranchAttendanceSummaryModel { Date = DateTime.Today };
                  ClearSelectedEmployee();
              }
          }
      }

    private async Task LoadSelectedEmployeeWorkspaceAsync()
    {
        if (SelectedBranch is null || SelectedEmployee is null)
            return;

        SelectedEmployeeAttendance = (await TenantAdminApiClient.GetEmployeeAttendanceAsync(SessionState, SelectedBranch.Id, SelectedEmployee.Id)).ToList();
        SelectedEmployeeShifts = (await TenantAdminApiClient.GetEmployeeShiftsAsync(SessionState, SelectedBranch.Id, SelectedEmployee.Id)).ToList();
        SelectedEmployeeLeaves = (await TenantAdminApiClient.GetEmployeeLeavesAsync(SessionState, SelectedBranch.Id, SelectedEmployee.Id)).ToList();
        SelectedEmployeeDocuments = (await TenantAdminApiClient.GetEmployeeDocumentsAsync(SessionState, SelectedBranch.Id, SelectedEmployee.Id)).ToList();
    }

    private async Task RefreshDashboardAsync()
    {
        IsBusy = true;
        ErrorMessage = string.Empty;
        FlashMessage = string.Empty;

        try
        {
            await LoadDashboardAsync();
            FlashMessage = "Dashboard refreshed successfully.";
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsBusy = false;
