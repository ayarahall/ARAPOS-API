                            <th>@UiLanguage.Text("Employee", "الموظف")</th>
                            <th>@UiLanguage.Text("Salary", "الراتب")</th>
                            <th>@UiLanguage.Text("Access", "الوصول")</th>
                            <th>@UiLanguage.Text("Today", "اليوم")</th>
                            <th>@UiLanguage.Text("Deduction", "الخصم")</th>
