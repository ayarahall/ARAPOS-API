    private async Task ImportBranchServicesAsync()
    {
        if (SelectedBranch is null || ServiceImportFile is null)
            return;

        IsImportingServices = true;
        ErrorMessage = string.Empty;
        FlashMessage = string.Empty;
        ServiceImportStatusSummary = string.Empty;

        try
        {
            await using var stream = ServiceImportFile.OpenReadStream(10 * 1024 * 1024);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);

            var result = await TenantAdminApiClient.ImportBranchServicesAsync(
                SessionState,
                SelectedBranch.Id,
                memoryStream.ToArray(),
                ServiceImportFile.Name);

              BranchServices = (await TenantAdminApiClient.GetBranchServicesAsync(SessionState, SelectedBranch.Id, null, 1, 200)).Items.ToList();
              SelectedService = null;
              UpdateServiceModel = new UpdateServiceRequestModel();
              ServiceImportFile = null;
              ServiceImportFileName = "No file selected.";

              FlashMessage = $"Excel import finished. Created: {result.CreatedCount}, updated: {result.UpdatedCount}, skipped: {result.SkippedCount}.";
              ServiceImportStatusSummary = $"Imported rows: {result.TotalRows}. Created: {result.CreatedCount}. Updated: {result.UpdatedCount}. Skipped: {result.SkippedCount}.";
              ErrorMessage = result.Issues.Count == 0
                  ? string.Empty
                  : string.Join(" | ", result.Issues.Take(5).Select(x => $"Row {x.RowNumber}: {x.Message}"));
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
            ServiceImportStatusSummary = "The import did not finish. Check the popup message, then try the template file again.";
        }
        finally
        {
            IsImportingServices = false;
        }
    }

