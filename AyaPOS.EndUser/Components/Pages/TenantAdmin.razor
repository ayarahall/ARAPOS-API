            await TenantAdminApiClient.CheckOutEmployeeAsync(SessionState, SelectedBranch.Id, SelectedEmployee.Id, new EmployeeAttendanceCheckOutRequestModel
            {
                AttendanceDate = AttendanceMarkDateValue,
                Notes = AttendanceMarkNotes
            });
