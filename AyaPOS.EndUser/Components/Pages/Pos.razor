@page "/pos"
@rendermode InteractiveServer
@using Ayapos.EndUser.Models.Cashier
@using Ayapos.EndUser.Models.Customers
@using Ayapos.EndUser.Models.Invoices
@using Ayapos.EndUser.Models.Products
@using Ayapos.EndUser.Models.Services
@using Ayapos.EndUser.Services.Auth
@using Ayapos.EndUser.Services.Cashier
@using Ayapos.EndUser.Services.Customers
@using Ayapos.EndUser.Services.Invoices
@using Ayapos.EndUser.Services.Products
@using Ayapos.EndUser.Services.Services
@inject NavigationManager NavigationManager
@inject SessionState SessionState
@inject CustomersApiClient CustomersApiClient
@inject ProductsApiClient ProductsApiClient
@inject ServicesApiClient ServicesApiClient
@inject InvoicesApiClient InvoicesApiClient
@inject CashierApiClient CashierApiClient
@inject IJSRuntime JSRuntime

<PageTitle>Point of Sale</PageTitle>

<div class="pos-shell">
    <NotificationPopup SuccessMessage="@FlashMessage" ErrorMessage="@ErrorMessage" />

    <header class="pos-topbar">
        <div class="pos-topbar-left">
            <button type="button" class="@(PosViewMode == "register" ? "pos-tab active" : "pos-tab")" @onclick='@(() => SetPosViewMode("register"))'>Register</button>
            <button type="button" class="@(PosViewMode == "orders" ? "pos-tab active" : "pos-tab")" @onclick='@(() => SetPosViewMode("orders"))'>Orders</button>
            <button type="button" class="pos-square-button" @onclick="StartNewSaleAsync" disabled="@IsBusy">+</button>
            <div class="pos-ticket-badge">@DraftReferenceLabel</div>
        </div>

        <div class="pos-topbar-right">
            <div class="pos-search-box">
                <span class="pos-search-icon">Q</span>
                <input class="pos-search-input" @bind="CatalogSearchText" @bind:event="oninput" placeholder="Search products..." />
            </div>
            <div class="pos-branch-chip">@BranchShortCode</div>
            <div class="pos-user-chip">@UserInitial</div>
            <button type="button" class="pos-menu-button" @onclick="ToggleRightMenu">Menu</button>
        </div>
    </header>

    <div class="pos-tabs-wrap">
        <RoleAwareSectionTabs Current="pos" />
    </div>

    <div class="pos-main">
        <aside class="pos-order-panel">
            <div class="pos-order-header">
                <div>
                    <div class="pos-order-label">Branch</div>
                    <div class="pos-order-value">@BranchLabel</div>
                </div>
                <div>
                    <div class="pos-order-label">Invoice</div>
                    <div class="pos-order-value">@DraftStateLabel</div>
                </div>
            </div>

            <div class="pos-status-strip">
                <div class="pos-status-card">
                    <span>Drawer</span>
                    <strong>@CashierStateLabel</strong>
                </div>
                <div class="pos-status-card">
                    <span>Status</span>
                    <strong>@CurrentInvoiceStatusLabel</strong>
                </div>
                <div class="pos-status-card">
                    <span>Remaining</span>
                    <strong>@RemainingSummary</strong>
                </div>
            </div>

            <div class="pos-customer-box">
                <div class="pos-customer-field">
                    <div class="pos-section-title">Customer</div>
                    <select class="form-input pos-customer-select" @bind="SelectedCustomerId">
                        <option value="">Walk-in / No customer</option>
                        @foreach (var customer in CustomerOptions)
                        {
                            <option value="@customer.Id">@customer.FullName (@(string.IsNullOrWhiteSpace(customer.Phone) ? "No phone" : customer.Phone))</option>
                        }
                    </select>
                </div>

                <div class="pos-customer-actions">
                    @if (CurrentInvoice is not null && string.Equals(CurrentInvoice.Status, "Draft", StringComparison.OrdinalIgnoreCase))
                    {
                        <button type="button" class="pos-ghost-action" @onclick="ApplyCustomerToCurrentInvoiceAsync" disabled="@IsBusy">Apply To Draft</button>
                    }

                    <button type="button" class="pos-ghost-action" @onclick="OpenQuickCustomerModal" disabled="@IsBusy">Search / Add Customer</button>

                    @if (!string.IsNullOrWhiteSpace(SelectedCustomerId))
                    {
                        <button type="button" class="pos-ghost-action" @onclick="ClearSelectedCustomer" disabled="@IsBusy">Clear</button>
                    }
                </div>
            </div>

            <div class="pos-lines-list">
                @if (CurrentInvoice is null)
                {
                    <div class="pos-empty-state">Create a draft to start selling.</div>
                }
                else if (CurrentInvoice.Items.Count == 0)
                {
                    <div class="pos-empty-state">Draft is ready. Pick a product or service from the catalog.</div>
                }
                else
                {
                    @foreach (var item in CurrentInvoice.Items)
                    {
                        <article class="pos-line-item @(SelectedLineId == item.Id ? "selected" : string.Empty)">
                            <div class="pos-line-top">
                                <span class="pos-line-qty">@item.Qty</span>
                                <div class="pos-line-name-block">
                                    <div class="pos-line-name">@item.Name</div>
                                    <div class="pos-line-meta">@item.ItemType</div>
                                </div>
                                <div class="pos-line-total">@FormatMoney(item.LineTotal)</div>
                            </div>
                            <div class="pos-line-actions">
                                <button type="button" class="pos-ghost-action" @onclick="() => SelectLine(item)">Edit</button>
                                <button type="button" class="pos-ghost-action danger" @onclick="() => RemoveLineAsync(item.Id)" disabled="@IsBusy">Remove</button>
                            </div>
                        </article>
                    }
                }
            </div>

            <div class="pos-summary-box">
                <div class="pos-summary-row">
                    <span>Taxes</span>
                    <strong>0 AED</strong>
                </div>
                <div class="pos-summary-row pos-summary-total">
                    <span>Total</span>
                    <strong>@InvoiceTotalSummary</strong>
                </div>
            </div>

            <div class="pos-order-actions">
                <button type="button" class="pos-mini-button" @onclick="StartNewSaleAsync" disabled="@IsBusy">New Sale</button>
                <button type="button" class="pos-mini-button" @onclick="ReloadInvoiceAsync" disabled="@(IsBusy || CurrentInvoice is null)">Reload</button>
                <button type="button" class="pos-mini-icon" @onclick="RefreshPosAsync">...</button>
            </div>

            <div class="pos-input-mode-row">
                <button type="button" class="@(InputMode == "qty" ? "pos-keypad-mode active" : "pos-keypad-mode")" @onclick='@(() => SetInputMode("qty"))'>Qty</button>
                <button type="button" class="@(InputMode == "price" ? "pos-keypad-mode active" : "pos-keypad-mode")" @onclick='@(() => SetInputMode("price"))'>Price</button>
            </div>

            @if (SelectedLine is not null)
            {
                <div class="pos-selected-line-panel">
                    <div class="pos-section-title">Selected Line</div>
                    <div class="pos-selected-line-name">@SelectedLine.Name</div>
                    <div class="pos-selected-line-meta">@SelectedLine.ItemType</div>
                    <div class="pos-payment-actions">
                        <button type="button" class="pos-ghost-action" @onclick="ApplyLineUpdateAsync" disabled="@IsBusy">Apply Qty / Price</button>
                        <button type="button" class="pos-ghost-action" @onclick="ClearLineSelection">Cancel Edit</button>
                    </div>
                </div>
            }

            <div class="pos-live-inputs">
                <div class="pos-live-input-card">
                    <span>Qty</span>
                    <strong>@Quantity</strong>
                </div>
                <div class="pos-live-input-card">
                    <span>Price</span>
                    <strong>@FormatMoney(PriceValue)</strong>
                </div>
            </div>

            <div class="pos-keypad-grid">
                @foreach (var key in KeypadKeys)
                {
                    <button type="button" class="@(key.IsAction ? "pos-keypad-key action" : "pos-keypad-key")" @onclick="() => OnKeypadPressed(key.Value)">@key.Label</button>
                }
            </div>

            @if (CurrentInvoice is not null)
            {
                <div class="pos-payment-panel">
                    <div class="pos-section-title">Payment Desk</div>

                    <div class="pos-payment-summary">
                        <div class="pos-payment-metric">
                            <span>Total</span>
                            <strong>@FormatMoney(CurrentInvoice.Total)</strong>
                        </div>
                        <div class="pos-payment-metric">
                            <span>Paid</span>
                            <strong>@FormatMoney(CurrentInvoice.TotalPaid)</strong>
                        </div>
                        <div class="pos-payment-metric">
                            <span>Remaining</span>
                            <strong>@FormatMoney(CurrentInvoice.Remaining)</strong>
                        </div>
                    </div>

                    @if (CanCollectPayment)
                    {
                        <div class="pos-payment-grid">
                            <select class="form-input" @bind="PaymentMethod">
                                <option value="1">Cash</option>
                                <option value="2">Card</option>
                                <option value="3">Bank Transfer</option>
                                <option value="4">Online</option>
                                <option value="5">Wallet</option>
                            </select>
                            <input class="form-input" type="number" step="0.01" min="0.01" @bind="PaymentAmount" placeholder="Amount" />
                            <input class="form-input" @bind="PaymentReference" placeholder="Reference" />
                        </div>

                        <div class="pos-payment-actions">
                            <button type="button" class="pos-ghost-action" @onclick="SetFullRemainingPayment" disabled="@IsBusy">Full Remaining</button>
                            <button type="button" class="pos-ghost-action" @onclick="SetHalfRemainingPayment" disabled="@IsBusy">Half Remaining</button>
                            <button type="button" class="pos-ghost-action" @onclick="AddPaymentAsync" disabled="@IsBusy">Record Payment</button>
                        </div>
                    }

                    <div class="pos-receipt-preview-toggle">
                        <button type="button" class="pos-ghost-action" @onclick="ToggleReceiptPreview" disabled="@(CurrentInvoice.Items.Count == 0)">@(ShowReceiptPreview ? "Hide Receipt" : "Show Receipt")</button>
                        <button type="button" class="pos-ghost-action" @onclick="PrintReceiptAsync" disabled="@(IsBusy || CurrentInvoice.Items.Count == 0)">Print Receipt</button>
                    </div>

                    @if (ShowReceiptPreview)
                    {
                        <div class="pos-receipt-preview">
                            <div class="pos-receipt-title">@CurrentInvoice.PrintSettings.ReceiptTitle</div>
                            @if (CurrentInvoice.PrintSettings.ShowBranchNameOnReceipt)
                            {
                                <div class="pos-receipt-line">@BranchLabel</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(CurrentInvoice.CustomerName) && CurrentInvoice.PrintSettings.ShowCustomerNameOnReceipt)
                            {
                                <div class="pos-receipt-line">Customer: @CurrentInvoice.CustomerName</div>
                            }
                            <div class="pos-receipt-line">Invoice: @CurrentInvoice.InvoiceCode</div>
                            <div class="pos-receipt-line">Items: @CurrentInvoice.Items.Count</div>
                            <div class="pos-receipt-divider"></div>
                            <div class="pos-receipt-row"><span>Total</span><strong>@FormatMoney(CurrentInvoice.Total)</strong></div>
                            <div class="pos-receipt-row"><span>Paid</span><strong>@FormatMoney(CurrentInvoice.TotalPaid)</strong></div>
                            <div class="pos-receipt-row"><span>Remaining</span><strong>@FormatMoney(CurrentInvoice.Remaining)</strong></div>
                            @if (!string.IsNullOrWhiteSpace(CurrentInvoice.PrintSettings.ReceiptFooterNote))
                            {
                                <div class="pos-receipt-divider"></div>
                                <div class="pos-receipt-footer">@CurrentInvoice.PrintSettings.ReceiptFooterNote</div>
                            }
                        </div>
                    }
                </div>
            }

            <button type="button" class="pos-payment-button" @onclick="HandlePrimaryPaymentActionAsync" disabled="@PrimaryPaymentDisabled">@PrimaryPaymentButtonLabel</button>
        </aside>

        <section class="pos-catalog-panel">
            @if (PosViewMode == "orders")
            {
                <div class="pos-catalog-toolbar">
                    <div class="pos-category-pills">
                        <button type="button" class="pos-category-pill mixed active">Recent Orders</button>
                    </div>

                    <div class="pos-toolbar-stats">
                        <span>@RecentInvoices.Count invoices</span>
                        <span>@DraftInvoicesCount drafts</span>
                        <span>@CashierStateLabel</span>
                    </div>
                </div>

                <div class="pos-orders-toolbar">
                    <input class="form-input" @bind="OrderSearchText" @bind:event="oninput" placeholder="Search by invoice code or customer" />
                    <select class="form-input" @bind="OrderStatusFilter">
                        <option value="all">All statuses</option>
                        <option value="draft">Draft only</option>
                        <option value="posted">Posted only</option>
                        <option value="partiallypaid">Partially paid</option>
                        <option value="paid">Paid</option>
                    </select>
                </div>

                <div class="pos-orders-grid">
                    @if (FilteredRecentInvoices.Count == 0)
                    {
                        <div class="pos-catalog-empty">No branch invoices are available yet.</div>
                    }
                    else
                    {
                        @foreach (var invoice in FilteredRecentInvoices)
                        {
                            <article class="pos-order-card @(CurrentInvoice?.Id == invoice.Id ? "selected" : string.Empty)">
                                <div class="pos-order-card-top">
                                    <div>
                                        <div class="pos-order-card-code">@invoice.InvoiceCode</div>
                                        <div class="pos-order-card-customer">@(string.IsNullOrWhiteSpace(invoice.CustomerName) ? "Walk-in" : invoice.CustomerName)</div>
                                    </div>
                                    <div class="pos-order-card-status">@invoice.Status</div>
                                </div>
                                <div class="pos-order-card-metrics">
                                    <span>Total: @FormatMoney(invoice.Total)</span>
                                    <span>Remaining: @FormatMoney(invoice.Remaining)</span>
                                </div>
                                <div class="pos-order-card-time">@invoice.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                                <div class="pos-order-card-actions">
                                    <button type="button" class="pos-ghost-action" @onclick="() => LoadInvoiceAsync(invoice.Id)">@(invoice.Status == "Draft" ? "Resume" : "Open")</button>
                                </div>
                            </article>
                        }
                    }
                </div>
            }
            else
            {
                <div class="pos-catalog-toolbar">
                    <div class="pos-category-pills">
                        <button type="button" class="@(CatalogMode == "product" ? "pos-category-pill active products" : "pos-category-pill products")" @onclick='@(() => SetCatalogMode("product"))'>Products</button>
                        <button type="button" class="@(CatalogMode == "service" ? "pos-category-pill active services" : "pos-category-pill services")" @onclick='@(() => SetCatalogMode("service"))'>Services</button>
                        <button type="button" class="@(CatalogMode == "all" ? "pos-category-pill active mixed" : "pos-category-pill mixed")" @onclick='@(() => SetCatalogMode("all"))'>All</button>
                    </div>

                    <div class="pos-toolbar-stats">
                        <span>@ProductOptions.Count products</span>
                        <span>@ServiceOptions.Count services</span>
                        <span>@CashierStateLabel</span>
                    </div>
                </div>

                <div class="pos-catalog-grid">
                    @if (CatalogCards.Count == 0)
                    {
                        <div class="pos-catalog-empty">No sellable items match the current search.</div>
                    }
                    else
                    {
                        @foreach (var card in CatalogCards)
                        {
                            <button type="button" class="pos-product-card" @onclick="() => AddCatalogCardAsync(card)">
                                <div class="pos-product-image">@card.Emoji</div>
                                <div class="pos-product-name">@card.Title</div>
                                <div class="pos-product-price">@card.PriceLabel</div>
                                <div class="pos-product-accent @card.AccentClass"></div>
                            </button>
                        }
                    }
                </div>
            }
        </section>
    </div>

    @if (ShowRightMenu)
    {
        <aside class="pos-side-drawer">
            <UserAccessCard ScopeLabel="Point Of Sale"
                            TenantLabel="@SessionState.TenantSlug"
                            BranchLabel="@BranchLabel"
                            UserName="@SessionState.Username"
                            RoleLabel="@RoleLabel"
                            Compact="true"
                            OnLogout="LogoutAsync" />
            <div class="pos-side-drawer-title">AyaPOS</div>
            <a class="pos-side-link" href="/workspace">Workspace</a>
            <a class="pos-side-link" href="/pos">Point of Sale</a>
            <a class="pos-side-link" href="/products">Products</a>
            <a class="pos-side-link" href="/services">Services</a>
            @if (SessionState.CanAccessCustomers)
            {
                <a class="pos-side-link" href="/customers">Customers</a>
            }
            @if (SessionState.CanAccessAppointments)
            {
                <a class="pos-side-link" href="/appointments">Appointments</a>
            }
            @if (SessionState.CanAccessExpenses)
            {
                <a class="pos-side-link" href="/expenses">Expenses</a>
            }
            <a class="pos-side-link" href="/cashier">Cashier Session</a>
            <a class="pos-side-link" href="/invoices">Invoices</a>
        </aside>
    }

    <ActionModal Visible="@ShowQuickCustomerModal"
                 Eyebrow="Quick Customer"
                 Title="Add customer inside POS"
                 Description="Search an existing customer or create a new one without leaving the selling screen."
                 OnClose="CloseQuickCustomerModal">
        <div class="showcase-header">
            <div>
                <span class="eyebrow">Existing Customer</span>
                <h2>Search and apply to this sale</h2>
            </div>
            <p>Use the existing customer list first, then create a new customer only if the client is not already saved.</p>
        </div>

        <div class="invoice-form-grid">
            <div class="field">
                <label for="posQuickCustomerSearch">Search Customer</label>
                <input id="posQuickCustomerSearch" class="form-input" @bind="QuickCustomerSearchText" @bind:event="oninput" placeholder="Search by name or phone" />
            </div>

            <div class="field">
                <label for="posQuickCustomerSelect">Existing Customer</label>
                <select id="posQuickCustomerSelect" class="form-input" @bind="QuickCustomerSelectedCustomerId">
                    <option value="">Select an existing customer</option>
                    @foreach (var customer in FilteredQuickCustomerOptions)
                    {
                        <option value="@customer.Id">@customer.FullName (@(string.IsNullOrWhiteSpace(customer.Phone) ? "No phone" : customer.Phone))</option>
                    }
                </select>
            </div>
        </div>

        <div class="invoice-actions">
            <button type="button" class="ghost-button" @onclick="ApplyExistingCustomerFromModalAsync" disabled="@IsBusy">Use Existing Customer</button>
        </div>

        <div class="showcase-header">
            <div>
                <span class="eyebrow">New Customer</span>
                <h2>Create a customer from POS</h2>
            </div>
            <p>This creates a customer under the current tenant and immediately makes it available for the current sale.</p>
        </div>

        <div class="invoice-form-grid">
            <div class="field">
                <label for="posQuickCustomerName">Full Name</label>
                <input id="posQuickCustomerName" class="form-input" @bind="QuickCustomerModel.FullName" />
            </div>

            <div class="field">
                <label for="posQuickCustomerPhone">Phone</label>
                <input id="posQuickCustomerPhone" class="form-input" @bind="QuickCustomerModel.Phone" />
            </div>

            <div class="field">
                <label for="posQuickCustomerEmail">Email</label>
                <input id="posQuickCustomerEmail" class="form-input" @bind="QuickCustomerModel.Email" />
            </div>

            <div class="field">
                <label for="posQuickCustomerNotes">Notes</label>
                <input id="posQuickCustomerNotes" class="form-input" @bind="QuickCustomerModel.Notes" />
            </div>
        </div>

        <div class="invoice-actions">
            <button type="button" class="submit-button" @onclick="CreateQuickCustomerAsync" disabled="@IsBusy">Create Customer In POS</button>
            <button type="button" class="ghost-button" @onclick="CloseQuickCustomerModal" disabled="@IsBusy">Cancel</button>
        </div>
    </ActionModal>

    <ActionModal Visible="@ShowFinalizeSaleModal"
                 Eyebrow="Finalize Sale"
                 Title="Finalize the current draft sale"
                 Description="This confirms the draft is ready to leave edit mode and move into the payment stage. Payment entry itself stays in the main POS screen."
                 OnClose="CloseFinalizeSaleModal">
        <div class="metrics-grid">
            <article class="metric-card">
                <span class="metric-label">Invoice</span>
                <strong class="metric-value">@DraftStateLabel</strong>
                <span class="metric-note">Current draft reference inside the branch POS workspace.</span>
            </article>

            <article class="metric-card">
                <span class="metric-label">Lines</span>
                <strong class="metric-value">@ItemCountSummary</strong>
                <span class="metric-note">All current product and service lines that will be locked into the invoice.</span>
            </article>

            <article class="metric-card accent">
                <span class="metric-label">Total</span>
                <strong class="metric-value">@InvoiceTotalSummary</strong>
                <span class="metric-note">This becomes the amount due after finalization.</span>
            </article>
        </div>

        <div class="invoice-actions">
            <button type="button" class="submit-button" @onclick="FinalizeInvoiceAsync" disabled="@IsBusy">Finalize Sale</button>
            <button type="button" class="ghost-button" @onclick="CloseFinalizeSaleModal" disabled="@IsBusy">Cancel</button>
        </div>
    </ActionModal>
</div>

@code {
    private bool _sessionChecked;
    private bool IsBusy { get; set; }
    private bool ShowRightMenu { get; set; }
    private bool ShowQuickCustomerModal { get; set; }
    private bool ShowFinalizeSaleModal { get; set; }
    private string ErrorMessage { get; set; } = string.Empty;
    private string FlashMessage { get; set; } = string.Empty;
    private string SelectedCustomerId { get; set; } = string.Empty;
    private string SelectedSourceType { get; set; } = "Product";
    private string SelectedItemId { get; set; } = string.Empty;
    private Guid? SelectedLineId { get; set; }
    private int Quantity { get; set; } = 1;
    private decimal PriceValue { get; set; }
    private string PosViewMode { get; set; } = "register";
    private string CatalogMode { get; set; } = "all";
    private string CatalogSearchText { get; set; } = string.Empty;
    private string OrderSearchText { get; set; } = string.Empty;
    private string OrderStatusFilter { get; set; } = "all";
    private string InputMode { get; set; } = "qty";
    private string QuickCustomerSearchText { get; set; } = string.Empty;
    private string QuickCustomerSelectedCustomerId { get; set; } = string.Empty;
    private bool ShowReceiptPreview { get; set; }
    private int PaymentMethod { get; set; } = 1;
    private decimal PaymentAmount { get; set; }
    private string PaymentReference { get; set; } = string.Empty;
    private CashierSessionModel? CurrentSession { get; set; }
    private InvoiceDetailsModel? CurrentInvoice { get; set; }
    private CreateCustomerRequestModel QuickCustomerModel { get; set; } = new();
    private List<CustomerListItemModel> CustomerOptions { get; set; } = [];
    private List<ProductListItemModel> ProductOptions { get; set; } = [];
    private List<ServiceListItemModel> ServiceOptions { get; set; } = [];
    private List<InvoiceListItemModel> RecentInvoices { get; set; } = [];

    private string BranchLabel => string.IsNullOrWhiteSpace(SessionState.BranchName) ? "Current Branch" : SessionState.BranchName;
    private string BranchShortCode => string.IsNullOrWhiteSpace(SessionState.BranchName) ? "BR" : SessionState.BranchName[..Math.Min(2, SessionState.BranchName.Length)].ToUpperInvariant();
    private string UserInitial => string.IsNullOrWhiteSpace(SessionState.Username) ? "A" : SessionState.Username[..1].ToUpperInvariant();
    private string RoleLabel => string.IsNullOrWhiteSpace(SessionState.Role) ? "Branch User" : SessionState.Role.Replace("_", " ");
    private string PosTitle => string.IsNullOrWhiteSpace(SessionState.BranchName)
        ? "Branch point-of-sale workspace"
        : $"{SessionState.BranchName} point-of-sale workspace";
    private string PosDescription => "This screen is for branch operations only: live sales, invoice building, and cashier flow.";
    private string CashierStateLabel => CurrentSession is null ? "Not Opened" : CurrentSession.IsClosed ? "Closed" : "Open";
    private string CashierStateNote => CurrentSession is null
        ? "Open the cashier session before collecting payments."
        : CurrentSession.IsClosed
            ? "The latest cashier session is already closed."
            : $"Expected cash: {FormatMoney(CurrentSession.ExpectedCashCents / 100m)}";
    private string DraftReferenceLabel => CurrentInvoice is null
        ? "1001"
        : string.IsNullOrWhiteSpace(CurrentInvoice.InvoiceCode)
            ? CurrentInvoice.Id.ToString()[..4].ToUpperInvariant()
            : CurrentInvoice.InvoiceCode;
    private string DraftStateLabel => CurrentInvoice is null ? "No Draft" : CurrentInvoice.InvoiceCode;
    private string DraftStateNote => CurrentInvoice is null
        ? "Create a draft invoice to begin the sale."
        : $"{CurrentInvoice.Items.Count} line(s) | Status: {CurrentInvoice.Status}";
    private string CurrentInvoiceStatusLabel => CurrentInvoice?.Status ?? "Draft pending";
    private string ItemCountSummary => CurrentInvoice is null ? "0 lines" : $"{CurrentInvoice.Items.Count} line(s)";
    private string InvoiceTotalSummary => CurrentInvoice is null ? "0 AED" : FormatMoney(CurrentInvoice.Total);
    private string RemainingSummary => CurrentInvoice is null ? "0 AED" : FormatMoney(CurrentInvoice.Remaining);
    private InvoiceItemModel? SelectedLine => CurrentInvoice?.Items.FirstOrDefault(x => x.Id == SelectedLineId);
    private int DraftInvoicesCount => RecentInvoices.Count(x => string.Equals(x.Status, "Draft", StringComparison.OrdinalIgnoreCase));
    private IReadOnlyList<CustomerListItemModel> FilteredQuickCustomerOptions
        => string.IsNullOrWhiteSpace(QuickCustomerSearchText)
            ? CustomerOptions
            : CustomerOptions
