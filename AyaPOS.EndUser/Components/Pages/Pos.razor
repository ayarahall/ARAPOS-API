    private async Task HandlePrimaryPaymentActionAsync()
    {
        if (CanFinalizeInvoice)
        {
            OpenFinalizeSaleModal();
            return;
        }

        if (CanCollectPayment)
        {
            if (PaymentAmount <= 0)
                SetFullRemainingPayment();

            await AddPaymentAsync();
        }
    }

    private async Task AddPaymentAsync()
    {
        if (!CanCollectPayment || CurrentInvoice is null)
            return;

        if (PaymentAmount <= 0)
        {
            ErrorMessage = "Payment amount must be greater than zero.";
            FlashMessage = string.Empty;
            return;
        }

        IsBusy = true;
        ErrorMessage = string.Empty;
        FlashMessage = string.Empty;

        try
        {
            var cents = (int)Math.Round(PaymentAmount * 100m, MidpointRounding.AwayFromZero);
            CurrentInvoice = await InvoicesApiClient.AddPaymentAsync(SessionState, CurrentInvoice.Id, new AddPaymentRequestModel
            {
                Method = PaymentMethod,
                AmountCents = cents,
                Reference = string.IsNullOrWhiteSpace(PaymentReference) ? null : PaymentReference.Trim()
            });

            FlashMessage = "Payment recorded successfully.";
            PaymentReference = string.Empty;
            PaymentAmount = CurrentInvoice.Remaining > 0 ? CurrentInvoice.Remaining : 0;
            ShowReceiptPreview = true;

            if (CurrentInvoice.PrintSettings.AutoPrintReceiptAfterPayment)
                await PrintReceiptAsync();

            await LoadRecentInvoicesAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsBusy = false;
        }
    }

    private void SetFullRemainingPayment()
    {
