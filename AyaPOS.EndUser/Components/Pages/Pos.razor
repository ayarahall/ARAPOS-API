    private bool MatchesOrderStatus(InvoiceListItemModel invoice)
    {
        if (string.Equals(OrderStatusFilter, "all", StringComparison.OrdinalIgnoreCase))
            return true;

        return string.Equals(invoice.Status.Replace("_", string.Empty), OrderStatusFilter, StringComparison.OrdinalIgnoreCase);
    }

    private bool MatchesOrderSearch(InvoiceListItemModel invoice)
    {
        if (string.IsNullOrWhiteSpace(OrderSearchText))
            return true;

        var term = OrderSearchText.Trim();

        return (!string.IsNullOrWhiteSpace(invoice.InvoiceCode) && invoice.InvoiceCode.Contains(term, StringComparison.OrdinalIgnoreCase))
               || (!string.IsNullOrWhiteSpace(invoice.CustomerName) && invoice.CustomerName.Contains(term, StringComparison.OrdinalIgnoreCase));
    }

