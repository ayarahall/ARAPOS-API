    private void OnKeypadPressed(string value)
    {
        if (value == "clear")
        {
            if (InputMode == "qty")
                Quantity = 1;
            else
                PriceValue = 0;

            return;
        }

        if (value == "back")
        {
            if (InputMode == "qty")
            {
                var text = Quantity.ToString();
                text = text.Length > 1 ? text[..^1] : "0";
                Quantity = int.TryParse(text, out var parsedQty) ? Math.Max(parsedQty, 0) : 0;
            }
            else
            {
                var text = PriceValue.ToString("0.##");
                text = text.Length > 1 ? text[..^1] : "0";
                PriceValue = decimal.TryParse(text, out var parsedPrice) ? Math.Max(parsedPrice, 0) : 0;
            }

            return;
        }

        if (InputMode == "qty")
        {
            var nextQty = $"{(Quantity <= 0 ? string.Empty : Quantity.ToString())}{value}";
            if (int.TryParse(nextQty, out var qty))
                Quantity = qty;

            return;
        }

        var current = PriceValue <= 0 ? string.Empty : PriceValue.ToString("0.##");
        if (value == "." && current.Contains('.'))
            return;

        var nextPrice = string.IsNullOrWhiteSpace(current) && value == "." ? "0." : $"{current}{value}";
        if (decimal.TryParse(nextPrice, out var price))
            PriceValue = price;
    }

    private void SyncPriceFromSelection()
    {
        if (!Guid.TryParse(SelectedItemId, out var itemId))
            return;

        if (SelectedSourceType == "Service")
        {
            var service = ServiceOptions.FirstOrDefault(x => x.Id == itemId);
            if (service is not null)
                PriceValue = service.Price;

            return;
        }

        var product = ProductOptions.FirstOrDefault(x => x.Id == itemId);
        if (product?.SellPrice is not null)
            PriceValue = product.SellPrice.Value;
    }

    private IReadOnlyList<CatalogCard> BuildCatalogCards()
    {
        var cards = new List<CatalogCard>();
        var search = CatalogSearchText.Trim();

        if (CatalogMode is "product" or "all")
        {
            cards.AddRange(ProductOptions
                .Where(product => MatchesSearch(GetProductDisplayName(product), product.Sku, search))
                .Select(product => new CatalogCard(
                    product.Id,
                    "Product",
                    GetProductDisplayName(product),
                    product.SellPrice ?? 0,
                    FormatProductPrice(product),
                    PickEmoji(GetProductDisplayName(product)),
                    PickAccent(GetProductDisplayName(product)))));
        }

        if (CatalogMode is "service" or "all")
        {
            cards.AddRange(ServiceOptions
                .Where(service => MatchesSearch(GetServiceDisplayName(service), null, search))
                .Select(service => new CatalogCard(
                    service.Id,
                    "Service",
                    GetServiceDisplayName(service),
                    service.Price,
                    FormatServicePrice(service),
                    "S",
                    "accent-blue")));
        }

        return cards.OrderBy(card => card.Title).ToList();
    }

    private IReadOnlyList<PosCard> BuildQuickSellCards()
    {
        var cards = new List<PosCard>();

        foreach (var product in ProductOptions.Take(3))
        {
            cards.Add(new PosCard(
                "PRODUCT",
                GetProductDisplayName(product),
                product.SellPrice is null ? "Price pending" : $"{product.SellPrice:0.##} {product.CurrencyCode}",
                "Ready for quick sale from the product catalog."));
        }

        foreach (var service in ServiceOptions.Take(3))
        {
            cards.Add(new PosCard(
                "SERVICE",
                GetServiceDisplayName(service),
                service.Price > 0 ? $"{service.Price:0.##} {service.CurrencyCode}" : "Price pending",
                $"Duration: {FormatDuration(service.DurationMin)}"));
        }

        return cards;
    }

    private static bool MatchesSearch(string name, string? code, string search)
        => string.IsNullOrWhiteSpace(search)
           || name.Contains(search, StringComparison.OrdinalIgnoreCase)
           || (!string.IsNullOrWhiteSpace(code) && code.Contains(search, StringComparison.OrdinalIgnoreCase));

    private static IReadOnlyList<KeypadKey> BuildKeypad()
        =>
        [
            new("1", "1"),
            new("2", "2"),
            new("3", "3"),
            new("4", "4"),
            new("5", "5"),
            new("6", "6"),
            new("7", "7"),
            new("8", "8"),
            new("9", "9"),
            new("+/-", "clear", true),
            new("0", "0"),
            new(".", ".", true),
            new("Del", "back", true)
        ];

    private static string PickEmoji(string name)
    {
        var lower = name.ToLowerInvariant();

        if (lower.Contains("shirt") || lower.Contains("lashes"))
            return "P";

        if (lower.Contains("jean") || lower.Contains("pant"))
            return "J";

        if (lower.Contains("shoe"))
            return "S";

        if (lower.Contains("hat"))
            return "H";

        return "Item";
    }

    private static string PickAccent(string name)
    {
        var seed = Math.Abs(name.GetHashCode()) % 4;
        return seed switch
        {
            0 => "accent-pink",
            1 => "accent-coral",
            2 => "accent-blue",
            _ => "accent-gold"
        };
    }

