                customerId = parsedCustomerId;

            await InvoicesApiClient.SetCustomerAsync(SessionState, CurrentInvoice.Id, new SetInvoiceCustomerRequestModel
            {
                CustomerId = customerId
            });

            CurrentInvoice = await InvoicesApiClient.GetInvoiceAsync(SessionState, CurrentInvoice.Id);
            if (showFlashMessage)
                FlashMessage = customerId is null
                    ? "Customer removed from the current draft."
                    : "Customer linked to the current draft.";
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsBusy = false;
        }
    }

