    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _sessionChecked)
            return;

        _sessionChecked = true;

        try
        {
            await SessionState.InitializeAsync();

            if (!SessionState.IsAuthenticated)
            {
                NavigationManager.NavigateTo("/");
                return;
            }

            if (!SessionState.CanAccessPos)
            {
                NavigationManager.NavigateTo(SessionState.IsTenantAdmin ? "/tenant-admin" : "/workspace");
                return;
            }

            await LoadPosAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }

        StateHasChanged();
    }

    private async Task LoadPosAsync()
    {
        ErrorMessage = string.Empty;
        var errors = new List<string>();

        try
        {
            var customers = await CustomersApiClient.GetCustomersAsync(SessionState, null, 1, 100);
            CustomerOptions = customers.Items.Where(x => x.IsActive).OrderBy(x => x.FullName).ToList();
        }
        catch (Exception ex)
        {
            CustomerOptions = [];
            errors.Add(ex.Message);
        }

        try
        {
            var products = await ProductsApiClient.GetProductsAsync(SessionState, null, 1, 100);
            ProductOptions = products.Items.Where(x => x.IsActive).OrderBy(x => GetProductDisplayName(x)).ToList();
        }
        catch (Exception ex)
        {
            ProductOptions = [];
            errors.Add(ex.Message);
        }

        try
        {
            var services = await ServicesApiClient.GetServicesAsync(SessionState, null, 1, 100);
            ServiceOptions = services.Items.Where(x => x.IsActive).OrderBy(x => GetServiceDisplayName(x)).ToList();
        }
        catch (Exception ex)
        {
            ServiceOptions = [];
            errors.Add(ex.Message);
        }

        try
        {
            var invoices = await InvoicesApiClient.GetInvoicesAsync(SessionState, null, null, 1, 20);
            RecentInvoices = invoices.Items
                .OrderByDescending(x => x.CreatedAt)
                .ToList();
        }
        catch (Exception ex)
        {
            RecentInvoices = [];
            errors.Add(ex.Message);
        }

        try
        {
            CurrentSession = await CashierApiClient.GetCurrentSessionAsync(SessionState);
        }
        catch
        {
            CurrentSession = null;
        }

        if (CurrentInvoice is not null)
            CurrentInvoice = await InvoicesApiClient.GetInvoiceAsync(SessionState, CurrentInvoice.Id);

        ErrorMessage = errors.Count == 0 ? string.Empty : string.Join(" | ", errors.Distinct());
    }

