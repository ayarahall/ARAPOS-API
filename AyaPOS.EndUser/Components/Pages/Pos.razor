                ? $"Product {product.Sku}"
                : "Unnamed product";

    private static string GetServiceDisplayName(ServiceListItemModel service)
        => !string.IsNullOrWhiteSpace(service.NameEn)
            ? service.NameEn
            : $"Service {service.Id.ToString()[..8].ToUpperInvariant()}";

    private sealed record ItemOption(Guid Id, string Label);

    private sealed record PosCard(
        string Badge,
        string Title,
        string Value,
        string Description);

    private sealed record CatalogCard(
        Guid ItemId,
        string ItemType,
        string Title,
        decimal Price,
        string PriceLabel,
        string Emoji,
        string AccentClass);

    private sealed record KeypadKey(
        string Label,
        string Value,
        bool IsAction = false);
}
