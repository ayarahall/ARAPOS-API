    private async Task AddLineAsync()
    {
        if (CurrentInvoice is null)
        {
            ErrorMessage = "Create the draft invoice first.";
            return;
        }

        ErrorMessage = string.Empty;
        FlashMessage = string.Empty;

        if (!Guid.TryParse(SelectedItemId, out var itemId))
        {
            ErrorMessage = "Select a product or service first.";
            return;
        }

        if (Quantity <= 0)
        {
            ErrorMessage = "Quantity must be greater than zero.";
            return;
        }

        IsBusy = true;

        try
        {
            var cents = (int)Math.Round(PriceValue * 100m, MidpointRounding.AwayFromZero);
            await InvoicesApiClient.AddItemAsync(SessionState, CurrentInvoice.Id, new AddInvoiceLineRequestModel
            {
                ItemType = SelectedSourceType,
                ItemId = itemId,
                Qty = Quantity,
                PriceOverrideCents = cents,
                PriceOverrideReason = "POS screen"
            });

            CurrentInvoice = await InvoicesApiClient.GetInvoiceAsync(SessionState, CurrentInvoice.Id);
            FlashMessage = "Item added to draft successfully.";
            Quantity = 1;
            SelectedItemId = string.Empty;
            PriceValue = 0;
            ClearLineSelection();
            await LoadRecentInvoicesAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsBusy = false;
        }
    }

