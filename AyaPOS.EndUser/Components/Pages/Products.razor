@page "/products"
@rendermode InteractiveServer
@implements IDisposable
@using Ayapos.EndUser.Models.Products
@using Ayapos.EndUser.Services.Auth
@using Ayapos.EndUser.Services.Products
@inject NavigationManager NavigationManager
@inject SessionState SessionState
@inject ProductsApiClient ProductsApiClient

<PageTitle>Products</PageTitle>

<div class="products-page">
    <AppPageHeader Title="Products" Description="Browse branch products, spot ready-to-sell items quickly, and search the live catalog without leaving the workspace." SessionState="@SessionState" OnLogout="LogoutAsync" />

    <RoleAwareSectionTabs Current="products" />

    <section class="toolbar-panel">
        <div class="toolbar-grid products-toolbar-grid">
            <div>
                <input class="form-input" value="@SearchText" @oninput="OnSearchInputAsync" placeholder="Search by product name, SKU, or barcode" />
                <div class="search-hint">Results refresh automatically after a short pause.</div>
            </div>

            <select class="form-input compact-input" @bind="PageSize" @bind:after="PageSizeChangedAsync">
                <option value="10">10 / page</option>
                <option value="25">25 / page</option>
                <option value="50">50 / page</option>
                <option value="100">100 / page</option>
            </select>

            <button class="submit-button" @onclick="RefreshAsync" disabled="@IsLoading">@(IsLoading ? "Refreshing..." : "Refresh")</button>
        </div>
    </section>

    <NotificationPopup SuccessMessage="@FlashMessage" ErrorMessage="@ErrorMessage" />

    <section class="metrics-grid">
        <article class="metric-card">
            <span class="metric-label">Visible Products</span>
            <strong class="metric-value">@TotalCount</strong>
            <span class="metric-note">Current live results from the selected branch.</span>
        </article>

        <article class="metric-card">
            <span class="metric-label">Active on Screen</span>
            <strong class="metric-value">@ActiveCount</strong>
            <span class="metric-note">Items on this page that are ready for sale.</span>
        </article>

        <article class="metric-card">
            <span class="metric-label">Priced Items</span>
            <strong class="metric-value">@PricedCount</strong>
            <span class="metric-note">Products currently showing a sell price.</span>
        </article>

        <article class="metric-card accent">
            <span class="metric-label">Page Status</span>
            <strong class="metric-value">@PageSummary</strong>
            <span class="metric-note">Use search or paging to move through the catalog.</span>
        </article>
    </section>

    <section class="showcase-panel">
        <div class="showcase-header">
            <div>
                <span class="eyebrow">Quick Picks</span>
                <h2>Products ready to scan and sell</h2>
            </div>
            <p>The first active products with pricing are surfaced here for faster daily access.</p>
        </div>

        @if (IsLoading && ProductItems.Count == 0)
        {
            <div class="placeholder-panel" style="margin-top:20px;">Loading products...</div>
        }
        else if (FeaturedProducts.Count == 0)
        {
            <div class="placeholder-panel" style="margin-top:20px;">No featured products are available yet. Add English product names and prices to make this area more useful.</div>
        }
        else
        {
            <div class="featured-products-grid">
                @foreach (var product in FeaturedProducts)
                {
                    <article class="product-feature-card">
                        <div class="product-feature-topline">
                            <span class="status-pill @(product.IsActive ? "active" : "inactive")">@(product.IsActive ? "Active" : "Inactive")</span>
                            <span class="product-feature-id">@GetCompactCode(product)</span>
                        </div>
                        <h3>@GetProductDisplayName(product)</h3>
                        <div class="product-feature-price">@FormatPrice(product)</div>
                        <div class="product-feature-meta">SKU: @(string.IsNullOrWhiteSpace(product.Sku) ? "Not set" : product.Sku)</div>
                        <div class="product-feature-meta">Barcode: @(string.IsNullOrWhiteSpace(product.Barcode) ? "Not set" : product.Barcode)</div>
                    </article>
                }
            </div>
        }
    </section>

    <section class="showcase-panel">
        <div class="showcase-header">
            <div>
                <span class="eyebrow">Create Product</span>
                <h2>Manage branch products</h2>
            </div>
            <p>Create sellable items from a popup, then open the selected product in a focused manage window instead of stretching the page.</p>
        </div>

        @if (CanManageCatalog)
        {
            <div class="invoice-actions" style="margin-top:16px;">
                <button class="submit-button" @onclick="OpenCreateProductModal" disabled="@IsLoading">Create Product</button>
                <button class="ghost-button" @onclick="RefreshAsync" disabled="@IsLoading">Refresh Catalog</button>
            </div>
        }
        else
        {
            <div class="placeholder-panel" style="margin-top:20px;">Product catalog setup is managed from the tenant admin side. Branch users can browse products here and sell them from POS only.</div>
        }
    </section>

    <section class="products-table-wrap">
        @if (!IsLoading && ProductItems.Count == 0)
        {
            <div class="placeholder-panel" style="margin-top:20px;">No products match the current search.</div>
        }
        else if (ProductItems.Count > 0)
        {
            <table class="products-table">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>SKU</th>
                        <th>Barcode</th>
                        <th>Price</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in ProductItems)
                    {
                        <tr>
                            <td>
                                <div class="table-primary-cell">@GetProductDisplayName(product)</div>
                                <div class="table-secondary-cell">@GetCompactCode(product)</div>
                            </td>
                            <td>@(product.Sku ?? "-")</td>
                            <td>@(product.Barcode ?? "-")</td>
                            <td>@FormatPrice(product)</td>
                            <td>
                                <span class="status-pill @(product.IsActive ? "active" : "inactive")">
                                    @(product.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td>
                                @if (CanManageCatalog)
                                {
                                    <button class="ghost-button" @onclick="() => SelectProduct(product)">Manage</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>

    <section class="pagination-panel">
        <button class="ghost-button" @onclick="PreviousPageAsync" disabled="@(IsLoading || CurrentPage <= 1)">Previous</button>
        <div class="pagination-summary">@PageSummary</div>
        <button class="ghost-button" @onclick="NextPageAsync" disabled="@(IsLoading || CurrentPage >= TotalPages)">Next</button>
    </section>

    <ActionModal Visible="@ShowCreateProductModal"
                 Eyebrow="Create Product"
                 Title="Add a branch product"
                 Description="Create a new sellable product for this branch from one focused popup."
                 OnClose="CloseCreateProductModal">
        <div class="invoice-form-grid">
            <div class="field">
                <label for="createProductNameEn">English Name</label>
                <input id="createProductNameEn" class="form-input" @bind="CreateProductModel.NameEn" />
            </div>
            <div class="field">
                <label for="createProductNameAr">Arabic Name</label>
                <input id="createProductNameAr" class="form-input" @bind="CreateProductModel.NameAr" />
            </div>
            <div class="field">
                <label for="createProductSku">SKU</label>
                <input id="createProductSku" class="form-input" @bind="CreateProductModel.Sku" />
            </div>
            <div class="field">
                <label for="createProductBarcode">Barcode</label>
                <input id="createProductBarcode" class="form-input" @bind="CreateProductModel.Barcode" />
            </div>
            <div class="field">
                <label for="createProductPrice">Sell Price</label>
                <input id="createProductPrice" class="form-input" type="number" step="0.01" min="0" @bind="CreateProductModel.SellPrice" />
            </div>
            <div class="field">
                <label for="createProductCurrency">Currency</label>
                <input id="createProductCurrency" class="form-input" @bind="CreateProductModel.CurrencyCode" />
            </div>
            <div class="field">
                <label for="createProductUnit">Unit</label>
                <input id="createProductUnit" class="form-input" @bind="CreateProductModel.Unit" />
            </div>
            <div class="field">
                <label for="createProductStatus">Status</label>
                <select id="createProductStatus" class="form-input" @bind="CreateProductStatusValue">
                    <option value="true">Active</option>
                    <option value="false">Inactive</option>
                </select>
            </div>
        </div>
        <div class="action-modal-footer">
            <button class="ghost-button" @onclick="ResetCreateProductForm" disabled="@IsLoading">Reset</button>
            <button class="submit-button" @onclick="CreateProductAsync" disabled="@IsLoading">Create Product</button>
        </div>
    </ActionModal>

    <ActionModal Visible="@(ShowManageProductModal && SelectedProduct is not null)"
                 Eyebrow="Manage Product"
                 Title="@ManageProductTitle"
                 Description="Update pricing, status, and branch catalog details from one compact manage window."
                 OnClose="CloseManageProductModal">
        @if (SelectedProduct is not null)
        {
            <div class="invoice-form-grid">
                <div class="field">
                    <label for="updateProductNameEn">English Name</label>
                    <input id="updateProductNameEn" class="form-input" @bind="UpdateProductModel.NameEn" />
                </div>
                <div class="field">
                    <label for="updateProductNameAr">Arabic Name</label>
                    <input id="updateProductNameAr" class="form-input" @bind="UpdateProductModel.NameAr" />
                </div>
                <div class="field">
                    <label for="updateProductSku">SKU</label>
                    <input id="updateProductSku" class="form-input" @bind="UpdateProductModel.Sku" />
                </div>
                <div class="field">
                    <label for="updateProductBarcode">Barcode</label>
                    <input id="updateProductBarcode" class="form-input" @bind="UpdateProductModel.Barcode" />
                </div>
                <div class="field">
                    <label for="updateProductPrice">Sell Price</label>
                    <input id="updateProductPrice" class="form-input" type="number" step="0.01" min="0" @bind="UpdateProductModel.SellPrice" />
                </div>
                <div class="field">
                    <label for="updateProductCurrency">Currency</label>
                    <input id="updateProductCurrency" class="form-input" @bind="UpdateProductModel.CurrencyCode" />
                </div>
                <div class="field">
                    <label for="updateProductUnit">Unit</label>
                    <input id="updateProductUnit" class="form-input" @bind="UpdateProductModel.Unit" />
                </div>
                <div class="field">
                    <label for="updateProductStatus">Status</label>
                    <select id="updateProductStatus" class="form-input" @bind="SelectedProductStatusValue">
                        <option value="true">Active</option>
                        <option value="false">Inactive</option>
                    </select>
                </div>
            </div>

            <div class="action-modal-footer">
                <button class="ghost-button" @onclick="ToggleSelectedProductActiveAsync" disabled="@IsLoading">@(SelectedProduct.IsActive ? "Deactivate Product" : "Activate Product")</button>
                <button class="submit-button" @onclick="UpdateProductAsync" disabled="@IsLoading">Update Product</button>
            </div>
        }
    </ActionModal>
</div>

@code {
    private CancellationTokenSource? _searchDebounceCts;
    private bool _sessionChecked;
    private bool _disposed;
    private bool IsLoading { get; set; }
    private bool ShowCreateProductModal { get; set; }
    private bool ShowManageProductModal { get; set; }
    private string ErrorMessage { get; set; } = string.Empty;
    private string FlashMessage { get; set; } = string.Empty;
    private string SearchText { get; set; } = string.Empty;
    private int TotalCount { get; set; }
    private int CurrentPage { get; set; } = 1;
    private int PageSize { get; set; } = 25;
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(TotalCount / (double)PageSize));
    private int ActiveCount => ProductItems.Count(x => x.IsActive);
    private int PricedCount => ProductItems.Count(x => x.SellPrice is not null && x.SellPrice > 0);
    private IReadOnlyList<ProductListItemModel> FeaturedProducts => ProductItems
        .Where(x => x.IsActive)
        .OrderByDescending(x => x.SellPrice ?? 0)
        .ThenBy(x => GetProductDisplayName(x))
        .Take(4)
        .ToList();
    private bool CanManageCatalog => SessionState.IsTenantAdmin;
    private string PageSummary => TotalCount == 0 ? "No results" : $"Page {CurrentPage} of {TotalPages}";
    private string ManageProductTitle => SelectedProduct is null ? "Manage product" : GetProductDisplayName(SelectedProduct);
    private List<ProductListItemModel> ProductItems { get; set; } = [];
    private ProductListItemModel? SelectedProduct { get; set; }
    private CreateProductRequestModel CreateProductModel { get; set; } = new();
    private UpdateProductRequestModel UpdateProductModel { get; set; } = new();
    private string CreateProductStatusValue { get; set; } = "true";
    private string SelectedProductStatusValue { get; set; } = "true";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _sessionChecked)
            return;

        _sessionChecked = true;
        await SessionState.InitializeAsync();

        if (!SessionState.IsAuthenticated)
        {
            NavigationManager.NavigateTo("/");
            return;
        }

        if (!SessionState.CanAccessCatalog)
        {
            NavigationManager.NavigateTo(SessionState.IsTenantAdmin ? "/tenant-admin" : "/workspace");
            return;
        }

        await LoadProductsAsync();
        StateHasChanged();
    }

    private async Task OnSearchInputAsync(ChangeEventArgs args)
    {
        SearchText = args.Value?.ToString() ?? string.Empty;
        CurrentPage = 1;
        await QueueSearchAsync();
    }

    private async Task QueueSearchAsync()
    {
        _searchDebounceCts?.Cancel();
        _searchDebounceCts?.Dispose();
        _searchDebounceCts = new CancellationTokenSource();

        try { await Task.Delay(350, _searchDebounceCts.Token); }
        catch (TaskCanceledException) { return; }

        if (_disposed || !SessionState.IsAuthenticated)
            return;

        await InvokeAsync(LoadProductsAsync);
    }

    private async Task RefreshAsync()
    {
        CurrentPage = 1;
        FlashMessage = string.Empty;
        await LoadProductsAsync();
    }

    private async Task PageSizeChangedAsync()
    {
        CurrentPage = 1;
        await LoadProductsAsync();
    }

    private async Task PreviousPageAsync()
    {
        if (CurrentPage <= 1) return;
        CurrentPage--;
        await LoadProductsAsync();
    }

    private async Task NextPageAsync()
    {
        if (CurrentPage >= TotalPages) return;
        CurrentPage++;
        await LoadProductsAsync();
    }

    private async Task LoadProductsAsync()
    {
        if (!SessionState.IsAuthenticated) return;

        IsLoading = true;
        ErrorMessage = string.Empty;

        try
        {
            var result = await ProductsApiClient.GetProductsAsync(SessionState, SearchText, CurrentPage, PageSize);
            ProductItems = result.Items.ToList();
            TotalCount = result.Total;
            if (CurrentPage > TotalPages) CurrentPage = TotalPages;

            if (SelectedProduct is not null)
            {
                SelectedProduct = ProductItems.FirstOrDefault(x => x.Id == SelectedProduct.Id);
                if (SelectedProduct is not null)
                {
                    UpdateProductModel = MapUpdateModel(SelectedProduct);
                    SelectedProductStatusValue = SelectedProduct.IsActive ? "true" : "false";
                }
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
            ProductItems = [];
            TotalCount = 0;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task CreateProductAsync()
    {
        IsLoading = true;
        ErrorMessage = string.Empty;
        FlashMessage = string.Empty;

        try
        {
            CreateProductModel.IsActive = string.Equals(CreateProductStatusValue, "true", StringComparison.OrdinalIgnoreCase);
            await ProductsApiClient.CreateProductAsync(SessionState, CreateProductModel);
            ResetCreateProductForm();
            ShowCreateProductModal = false;
            FlashMessage = "Product created successfully.";
            CurrentPage = 1;
            await LoadProductsAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void ResetCreateProductForm()
    {
        CreateProductModel = new CreateProductRequestModel();
        CreateProductStatusValue = "true";
    }

    private void OpenCreateProductModal()
    {
        ResetCreateProductForm();
        ErrorMessage = string.Empty;
        FlashMessage = string.Empty;
        ShowCreateProductModal = true;
    }

    private Task CloseCreateProductModal()
    {
        ShowCreateProductModal = false;
        return Task.CompletedTask;
    }

    private void SelectProduct(ProductListItemModel product)
    {
        SelectedProduct = product;
        UpdateProductModel = MapUpdateModel(product);
        SelectedProductStatusValue = product.IsActive ? "true" : "false";
        ErrorMessage = string.Empty;
        FlashMessage = string.Empty;
        ShowManageProductModal = true;
    }

    private void ClearSelectedProduct()
    {
        SelectedProduct = null;
        UpdateProductModel = new UpdateProductRequestModel();
        SelectedProductStatusValue = "true";
        ShowManageProductModal = false;
    }

    private Task CloseManageProductModal()
    {
        ClearSelectedProduct();
        return Task.CompletedTask;
    }

    private async Task UpdateProductAsync()
    {
        if (SelectedProduct is null)
            return;

        IsLoading = true;
        ErrorMessage = string.Empty;
        FlashMessage = string.Empty;

        try
        {
            UpdateProductModel.IsActive = string.Equals(SelectedProductStatusValue, "true", StringComparison.OrdinalIgnoreCase);
            await ProductsApiClient.UpdateProductAsync(SessionState, SelectedProduct.Id, UpdateProductModel);
            ShowManageProductModal = false;
            FlashMessage = "Product updated successfully.";
            await LoadProductsAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task ToggleSelectedProductActiveAsync()
    {
        if (SelectedProduct is null)
            return;

        SelectedProductStatusValue = SelectedProduct.IsActive ? "false" : "true";
        await UpdateProductAsync();
    }

    private async Task LogoutAsync()
    {
        await SessionState.SignOutAsync();
        NavigationManager.NavigateTo("/");
    }

    private static string FormatPrice(ProductListItemModel product)
        => product.SellPrice is null ? "Price pending" : $"{product.SellPrice:0.##} {product.CurrencyCode}";

    private static string GetProductDisplayName(ProductListItemModel product)
        => !string.IsNullOrWhiteSpace(product.NameEn)
            ? product.NameEn
            : !string.IsNullOrWhiteSpace(product.Sku)
                ? $"Product {product.Sku}"
                : "Unnamed product";

    private static string GetCompactCode(ProductListItemModel product)
        => !string.IsNullOrWhiteSpace(product.Sku)
            ? product.Sku
            : product.Id.ToString()[..8].ToUpperInvariant();

    private static UpdateProductRequestModel MapUpdateModel(ProductListItemModel product)
        => new()
        {
            Sku = product.Sku ?? string.Empty,
            Barcode = product.Barcode ?? string.Empty,
            NameAr = product.NameAr ?? string.Empty,
            NameEn = product.NameEn ?? string.Empty,
            Unit = string.IsNullOrWhiteSpace(product.Unit) ? "pcs" : product.Unit,
            SellPrice = product.SellPrice ?? 0,
            CurrencyCode = string.IsNullOrWhiteSpace(product.CurrencyCode) ? "AED" : product.CurrencyCode,
            IsActive = product.IsActive,
            TrackInventory = product.TrackInventory
        };

    public void Dispose()
    {
        _disposed = true;
        _searchDebounceCts?.Cancel();
        _searchDebounceCts?.Dispose();
    }
}
