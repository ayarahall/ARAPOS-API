@page "/invoices"
@rendermode InteractiveServer
@implements IDisposable
@using Ayapos.EndUser.Models.Invoices
@using Ayapos.EndUser.Services.Auth
@using Ayapos.EndUser.Services.Invoices
@inject NavigationManager NavigationManager
@inject SessionState SessionState
@inject InvoicesApiClient InvoicesApiClient

<PageTitle>Invoices</PageTitle>

<div class="products-page">
    <AppPageHeader Title="Invoices" Description="Review recent invoices, filter by status, and jump into payment-ready records from one clean screen." SessionState="@SessionState" OnLogout="LogoutAsync" />

    <RoleAwareSectionTabs Current="invoices" />

    <section class="showcase-panel">
        <div class="showcase-header">
            <div>
                <span class="eyebrow">Invoice Context</span>
                <h2>@InvoiceContextTitle</h2>
            </div>
            <p>@InvoiceContextDescription</p>
        </div>
    </section>

    <section class="toolbar-panel">
        <div class="invoice-actions" style="margin-bottom:16px;">
            <a class="submit-button action-link" href="/invoices/create">Create New Invoice</a>
        </div>

        <div class="toolbar-grid invoice-list-toolbar-grid">
            <div>
                <input class="form-input" value="@SearchText" @oninput="OnSearchInputAsync" placeholder="Search by invoice code" />
                <div class="search-hint">Results refresh automatically after a short pause.</div>
            </div>

            <select class="form-input compact-input" @bind="SelectedStatus" @bind:after="RefreshAsync">
                <option value="">All statuses</option>
                <option value="Draft">Draft</option>
                <option value="Posted">Posted</option>
                <option value="PartiallyPaid">Partially Paid</option>
                <option value="Paid">Paid</option>
            </select>

            <select class="form-input compact-input" @bind="PageSize" @bind:after="PageSizeChangedAsync">
                <option value="10">10 / page</option>
                <option value="25">25 / page</option>
                <option value="50">50 / page</option>
            </select>

            <button class="submit-button" @onclick="RefreshAsync" disabled="@IsLoading">@(IsLoading ? "Refreshing..." : "Refresh")</button>
        </div>
    </section>

    <NotificationPopup SuccessMessage="@FlashMessage" ErrorMessage="@ErrorMessage" />

    <section class="metrics-grid">
        <article class="metric-card">
            <span class="metric-label">Visible Invoices</span>
            <strong class="metric-value">@TotalCount</strong>
            <span class="metric-note">Current invoice results after applying search and status filters.</span>
        </article>

        <article class="metric-card">
            <span class="metric-label">Drafts on Screen</span>
            <strong class="metric-value">@DraftCount</strong>
            <span class="metric-note">Invoices still open for editing before finalizing.</span>
        </article>

        <article class="metric-card">
            <span class="metric-label">Paid on Screen</span>
            <strong class="metric-value">@PaidCount</strong>
            <span class="metric-note">Invoices that are already settled in full.</span>
        </article>

        <article class="metric-card accent">
            <span class="metric-label">Page Status</span>
            <strong class="metric-value">@PageSummary</strong>
            <span class="metric-note">Move through invoice history or jump into details for payment updates.</span>
        </article>
    </section>

    <section class="showcase-panel">
        <div class="showcase-header">
            <div>
                <span class="eyebrow">Quick Picks</span>
                <h2>Invoices that deserve attention first</h2>
            </div>
            <p>Open balances and recently created invoices are highlighted here to speed up daily cashier work.</p>
        </div>

        @if (IsLoading && InvoiceItems.Count == 0)
        {
            <div class="placeholder-panel" style="margin-top:20px;">Loading invoices...</div>
        }
        else if (FeaturedInvoices.Count == 0)
        {
            <div class="placeholder-panel" style="margin-top:20px;">No invoices matched the current filters.</div>
        }
        else
        {
            <div class="featured-products-grid">
                @foreach (var invoice in FeaturedInvoices)
                {
                    <article class="product-feature-card">
                        <div class="product-feature-topline">
                            <span class="status-pill @MapStatusClass(invoice.Status)">@invoice.Status</span>
                            <span class="product-feature-id">@invoice.InvoiceCode</span>
                        </div>
                        <h3>@(string.IsNullOrWhiteSpace(invoice.CustomerName) ? "Walk-in customer" : invoice.CustomerName)</h3>
                        <div class="product-feature-price">@FormatMoney(invoice.Remaining)</div>
                        <div class="product-feature-meta">Total: @FormatMoney(invoice.Total)</div>
                        <div class="product-feature-meta">Paid: @FormatMoney(invoice.TotalPaid)</div>
                    </article>
                }
            </div>
        }
    </section>

    <section class="products-table-wrap">
        @if (!IsLoading && InvoiceItems.Count == 0)
        {
            <div class="placeholder-panel" style="margin-top:20px;">No invoices matched the current filters.</div>
        }
        else if (InvoiceItems.Count > 0)
        {
            <table class="products-table">
                <thead>
                    <tr>
                        <th>Invoice Code</th>
                        <th>Customer</th>
                        <th>Status</th>
                        <th>Total</th>
                        <th>Paid</th>
                        <th>Remaining</th>
                        <th>Created</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var invoice in InvoiceItems)
                    {
                        <tr>
                            <td>
                                <div class="table-primary-cell">@invoice.InvoiceCode</div>
                                <div class="table-secondary-cell">@invoice.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                            </td>
                            <td>@(string.IsNullOrWhiteSpace(invoice.CustomerName) ? "Walk-in" : invoice.CustomerName)</td>
                            <td><span class="status-pill @MapStatusClass(invoice.Status)">@invoice.Status</span></td>
                            <td>@FormatMoney(invoice.Total)</td>
                            <td>@FormatMoney(invoice.TotalPaid)</td>
                            <td>@FormatMoney(invoice.Remaining)</td>
                            <td>@invoice.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            <td><a class="section-tab small-tab" href="@($"/invoices/{invoice.Id}")">Details</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>

    <section class="pagination-panel">
        <button class="ghost-button" @onclick="PreviousPageAsync" disabled="@(IsLoading || CurrentPage <= 1)">Previous</button>
        <div class="pagination-summary">@PageSummary</div>
        <button class="ghost-button" @onclick="NextPageAsync" disabled="@(IsLoading || CurrentPage >= TotalPages)">Next</button>
    </section>
</div>

@code {
    private CancellationTokenSource? _searchDebounceCts;
    private bool _sessionChecked;
    private bool _disposed;
    private bool IsLoading { get; set; }
    private string ErrorMessage { get; set; } = string.Empty;
    private string FlashMessage { get; set; } = string.Empty;
    private string SearchText { get; set; } = string.Empty;
    private string SelectedStatus { get; set; } = string.Empty;
    private int TotalCount { get; set; }
    private int CurrentPage { get; set; } = 1;
    private int PageSize { get; set; } = 25;
    private int TotalPages => Math.Max(1, (int)Math.Ceiling(TotalCount / (double)PageSize));
    private int DraftCount => InvoiceItems.Count(x => x.Status == "Draft");
    private int PaidCount => InvoiceItems.Count(x => x.Status == "Paid");
    private IReadOnlyList<InvoiceListItemModel> FeaturedInvoices => InvoiceItems
        .OrderByDescending(x => x.Remaining)
        .ThenByDescending(x => x.CreatedAt)
        .Take(4)
        .ToList();
    private string InvoiceContextTitle => string.IsNullOrWhiteSpace(SessionState.BranchName)
        ? "Current branch invoices"
        : $"{SessionState.BranchName} invoices";
    private string InvoiceContextDescription => string.IsNullOrWhiteSpace(SelectedStatus)
        ? "Use search, status filters, and quick picks to move through branch invoices faster."
        : $"The list is currently filtered to {SelectedStatus} invoices for this branch.";
    private string PageSummary => TotalCount == 0 ? "No results" : $"Page {CurrentPage} of {TotalPages}";
    private List<InvoiceListItemModel> InvoiceItems { get; set; } = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _sessionChecked) return;
        _sessionChecked = true;
        try
        {
            await SessionState.InitializeAsync();
            if (!SessionState.IsAuthenticated)
            {
                NavigationManager.NavigateTo("/");
                return;
            }
            if (!SessionState.CanAccessInvoices)
            {
                NavigationManager.NavigateTo(SessionState.IsTenantAdmin ? "/tenant-admin" : "/workspace");
                return;
            }
            await LoadInvoicesAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        StateHasChanged();
    }

    private async Task OnSearchInputAsync(ChangeEventArgs args)
    {
        SearchText = args.Value?.ToString() ?? string.Empty;
        CurrentPage = 1;
        await QueueSearchAsync();
    }

    private async Task QueueSearchAsync()
    {
        _searchDebounceCts?.Cancel();
        _searchDebounceCts?.Dispose();
        _searchDebounceCts = new CancellationTokenSource();
        try { await Task.Delay(350, _searchDebounceCts.Token); }
        catch (TaskCanceledException) { return; }
        if (_disposed || !SessionState.IsAuthenticated) return;
        await InvokeAsync(LoadInvoicesAsync);
    }

    private async Task RefreshAsync()
    {
        CurrentPage = 1;
        FlashMessage = string.Empty;
        await LoadInvoicesAsync();
    }
    private async Task PageSizeChangedAsync() { CurrentPage = 1; await LoadInvoicesAsync(); }
    private async Task PreviousPageAsync() { if (CurrentPage <= 1) return; CurrentPage--; await LoadInvoicesAsync(); }
    private async Task NextPageAsync() { if (CurrentPage >= TotalPages) return; CurrentPage++; await LoadInvoicesAsync(); }

    private async Task LoadInvoicesAsync()
    {
        if (!SessionState.IsAuthenticated) return;
        IsLoading = true;
        ErrorMessage = string.Empty;
        try
        {
            var result = await InvoicesApiClient.GetInvoicesAsync(SessionState, SelectedStatus, SearchText, CurrentPage, PageSize);
            InvoiceItems = result.Items.ToList();
            TotalCount = result.Total;
            if (CurrentPage > TotalPages) CurrentPage = TotalPages;
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
            InvoiceItems = [];
            TotalCount = 0;
        }
        finally { IsLoading = false; }
    }

    private async Task LogoutAsync()
    {
        await SessionState.SignOutAsync();
        NavigationManager.NavigateTo("/");
    }

    private static string MapStatusClass(string status)
        => status is "Paid" ? "active" : status is "Draft" ? "inactive" : "warning";

    private static string FormatMoney(decimal amount) => $"{amount:0.##} AED";

    public void Dispose()
    {
        _disposed = true;
        _searchDebounceCts?.Cancel();
        _searchDebounceCts?.Dispose();
    }
}
