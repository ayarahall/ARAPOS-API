@code {
    private const int SchedulerStartHour = 10;
    private const int SchedulerEndHour = 23;
    private const double PixelsPerMinute = 1.2d;

    private bool _sessionChecked;
    private bool IsBusy { get; set; }
    private bool ShowCreateAppointmentModal { get; set; }
    private bool ShowManageAppointmentModal { get; set; }
    private string ErrorMessage { get; set; } = string.Empty;
    private string FlashMessage { get; set; } = string.Empty;
    private string SelectedCustomerId { get; set; } = string.Empty;
    private string ManageSelectedCustomerId { get; set; } = string.Empty;
    private string ManageSelectedServiceId { get; set; } = string.Empty;
    private string CustomerSearchText { get; set; } = string.Empty;
    private int TotalCount { get; set; }
    private DateTime SelectedScheduleDate { get; set; } = DateTime.Today;
    private string ScheduleMode { get; set; } = "day";
    private DateTime? SelectedSlotStart { get; set; }
    private List<AppointmentListItemModel> AppointmentItems { get; set; } = [];
    private AppointmentScheduleBoardModel ScheduleBoard { get; set; } = new();
    private List<AppointmentResourceModel> ResourceOptions { get; set; } = [];
    private List<CustomerListItemModel> CustomerOptions { get; set; } = [];
    private List<ServiceListItemModel> ServiceOptions { get; set; } = [];
    private CreateAppointmentRequestModel CreateModel { get; set; } = CreateDefaultAppointmentModel(DateTime.Today);
    private UpdateAppointmentRequestModel ManageAppointmentModel { get; set; } = new();
    private CreateCustomerRequestModel QuickCustomerModel { get; set; } = new();
    private AppointmentListItemModel? SelectedAppointment { get; set; }
    private static IReadOnlyList<string> AppointmentStatuses => ["scheduled", "confirmed", "completed", "cancelled", "no_show"];

    private string BranchLabel => string.IsNullOrWhiteSpace(SessionState.BranchName) ? "Current Branch" : SessionState.BranchName;
    private string AppointmentsTitle => string.IsNullOrWhiteSpace(SessionState.BranchName) ? "Branch appointments workspace" : $"{SessionState.BranchName} appointments workspace";
    private string AppointmentsDescription => "This screen is reserved for branch scheduling, specialist planning, and front-desk appointment flow.";
    private string AppointmentFocus => SessionState.IsHr ? "Resources & scheduling" : SessionState.IsBranchManager ? "Capacity & availability" : "Reception support";
    private IReadOnlyList<AppointmentScheduleColumnModel> ScheduleColumns => ScheduleBoard.Columns;
    private IReadOnlyList<string> HourLabels => Enumerable.Range(SchedulerStartHour, SchedulerEndHour - SchedulerStartHour).Select(FormatHourLabel).ToList();
    private string SchedulerColumnsStyle => $"--scheduler-columns:{Math.Max(1, ScheduleColumns.Count)};";
    private IReadOnlyList<WeeklyAgendaDay> WeeklyAgendaDays => BuildWeeklyAgendaDays();
    private IReadOnlyList<AgendaDayGroup> AgendaGroups => BuildAgendaGroups();
    private CustomerListItemModel? SelectedCustomer => Guid.TryParse(SelectedCustomerId, out var customerId) ? CustomerOptions.FirstOrDefault(x => x.Id == customerId) : null;
    private bool HasSelectedSlot => SelectedSlotStart.HasValue;
    private string SelectedServiceId
    {
        get => CreateModel.ServiceId?.ToString() ?? string.Empty;
        set
        {
            CreateModel.ServiceId = Guid.TryParse(value, out var parsedId) ? parsedId : null;
            CreateModel.EndAt = CreateModel.StartAt.AddMinutes(SelectedDurationMinutes);
        }
    }
    private ServiceListItemModel? SelectedService => CreateModel.ServiceId is null ? null : ServiceOptions.FirstOrDefault(x => x.Id == CreateModel.ServiceId.Value);
    private int SelectedDurationMinutes => Math.Max(30, SelectedService?.DurationMin ?? 60);
    private IReadOnlyList<DateTime> AvailableSlots => BuildAvailableSlots();
    private IReadOnlyList<CustomerListItemModel> FilteredCustomerOptions
        => string.IsNullOrWhiteSpace(CustomerSearchText)
            ? CustomerOptions
            : CustomerOptions.Where(customer =>
                    customer.FullName.Contains(CustomerSearchText.Trim(), StringComparison.OrdinalIgnoreCase) ||
                    (!string.IsNullOrWhiteSpace(customer.Phone) && customer.Phone.Contains(CustomerSearchText.Trim(), StringComparison.OrdinalIgnoreCase)))
                .ToList();
    private string AppointmentWindowLabel => $"{CreateModel.StartAt:dd MMM HH:mm} -> {CreateModel.EndAt:HH:mm}";
    private string ManageAppointmentTitle => SelectedAppointment is null
        ? "Edit appointment"
        : $"{(string.IsNullOrWhiteSpace(SelectedAppointment.CustomerName) ? "Walk-in" : SelectedAppointment.CustomerName)} appointment";
    private string StartAtInput
    {
        get => CreateModel.StartAt.ToString("yyyy-MM-ddTHH:mm");
        set { if (DateTime.TryParse(value, out var parsed)) CreateModel.StartAt = parsed; }
    }
    private string EndAtInput
    {
        get => CreateModel.EndAt.ToString("yyyy-MM-ddTHH:mm");
        set { if (DateTime.TryParse(value, out var parsed)) CreateModel.EndAt = parsed; }
    }
    private string ManageStartAtInput
    {
        get => ManageAppointmentModel.StartAt.ToString("yyyy-MM-ddTHH:mm");
        set { if (DateTime.TryParse(value, out var parsed)) ManageAppointmentModel.StartAt = parsed; }
    }
    private string ManageEndAtInput
    {
        get => ManageAppointmentModel.EndAt.ToString("yyyy-MM-ddTHH:mm");
        set { if (DateTime.TryParse(value, out var parsed)) ManageAppointmentModel.EndAt = parsed; }
    }

    private void OnStartAtChanged(ChangeEventArgs args) => StartAtInput = args.Value?.ToString() ?? StartAtInput;
    private void OnEndAtChanged(ChangeEventArgs args) => EndAtInput = args.Value?.ToString() ?? EndAtInput;
    private void OnManageStartAtChanged(ChangeEventArgs args) => ManageStartAtInput = args.Value?.ToString() ?? ManageStartAtInput;
    private void OnManageEndAtChanged(ChangeEventArgs args) => ManageEndAtInput = args.Value?.ToString() ?? ManageEndAtInput;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _sessionChecked) return;
        _sessionChecked = true;

        try
        {
            await SessionState.InitializeAsync();
            if (!SessionState.IsAuthenticated) { NavigationManager.NavigateTo("/"); return; }
            if (!SessionState.CanAccessAppointments) { NavigationManager.NavigateTo(SessionState.IsTenantAdmin ? "/tenant-admin" : "/workspace"); return; }

            SelectedScheduleDate = DateTime.Today;
            ResetCreateModelForDate(SelectedScheduleDate);
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }

        StateHasChanged();
    }

    private async Task LoadDataAsync()
    {
        ErrorMessage = string.Empty;

        var rangeStart = ScheduleMode == "week" ? StartOfWeek(SelectedScheduleDate) : SelectedScheduleDate.Date;
        var rangeEnd = ScheduleMode == "week" ? StartOfWeek(SelectedScheduleDate).AddDays(7) : SelectedScheduleDate.Date.AddDays(1);

        var appointmentsTask = AppointmentsApiClient.GetAppointmentsAsync(SessionState, null, null, rangeStart, rangeEnd, 1, 300);
        var scheduleTask = AppointmentsApiClient.GetScheduleAsync(SessionState, SelectedScheduleDate);
        var customersTask = CustomersApiClient.GetCustomersAsync(SessionState, null, 1, 200);
        var resourcesTask = AppointmentsApiClient.GetResourcesAsync(SessionState);
        var servicesTask = ServicesApiClient.GetServicesAsync(SessionState, null, 1, 200);
        await Task.WhenAll(appointmentsTask, scheduleTask, customersTask, resourcesTask, servicesTask);

        AppointmentItems = appointmentsTask.Result.Items
            .Where(item => item.StartAt.ToLocalTime() >= rangeStart && item.StartAt.ToLocalTime() < rangeEnd)
            .OrderBy(item => item.StartAt)
            .ToList();
        ScheduleBoard = scheduleTask.Result;
        TotalCount = AppointmentItems.Count;
        CustomerOptions = customersTask.Result.Items.Where(x => x.IsActive).OrderBy(x => x.FullName).ToList();
        ResourceOptions = resourcesTask.Result.OrderBy(x => x.Role).ThenBy(x => x.Username).ToList();
        ServiceOptions = servicesTask.Result.Items.Where(x => x.IsActive).OrderBy(GetServiceDisplayName).ToList();
    }

    private async Task RefreshAsync()
    {
        IsBusy = true;
        ErrorMessage = string.Empty;
        FlashMessage = string.Empty;
        try { await LoadDataAsync(); FlashMessage = "Appointments refreshed successfully."; }
        catch (Exception ex) { ErrorMessage = ex.Message; }
        finally { IsBusy = false; }
    }

    private async Task LoadTodayAsync() { SelectedScheduleDate = DateTime.Today; await ReloadScheduleDateAsync(); }
    private async Task LoadPreviousDayAsync() { SelectedScheduleDate = SelectedScheduleDate.AddDays(-1); await ReloadScheduleDateAsync(); }
    private async Task LoadNextDayAsync() { SelectedScheduleDate = SelectedScheduleDate.AddDays(1); await ReloadScheduleDateAsync(); }
    private async Task ChangeScheduleModeAsync(string mode)
    {
        ScheduleMode = mode == "week" ? "week" : mode == "agenda" ? "agenda" : "day";
        await ReloadScheduleDateAsync();
    }

    private async Task OnScheduleDateChanged(ChangeEventArgs args)
    {
        if (DateTime.TryParse(args.Value?.ToString(), out var parsed))
        {
            SelectedScheduleDate = parsed.Date;
            await ReloadScheduleDateAsync();
        }
    }

    private async Task ReloadScheduleDateAsync()
    {
        IsBusy = true;
        ErrorMessage = string.Empty;
        FlashMessage = string.Empty;
        try
        {
            ResetCreateModelForDate(SelectedScheduleDate);
            await LoadDataAsync();
            FlashMessage = $"Schedule loaded for {SelectedScheduleDate:dddd, dd MMM yyyy}.";
        }
        catch (Exception ex) { ErrorMessage = ex.Message; }
        finally { IsBusy = false; }
    }

    private async Task CreateAppointmentAsync()
    {
        if (!HasSelectedSlot)
        {
            ErrorMessage = "Choose a free slot before creating the appointment.";
            FlashMessage = string.Empty;
            return;
        }

        if (CreateModel.ServiceId is null)
        {
            ErrorMessage = "Select a branch service before booking the appointment.";
            FlashMessage = string.Empty;
            return;
        }

        IsBusy = true;
        ErrorMessage = string.Empty;
        FlashMessage = string.Empty;
        try
        {
            var parsedCustomerId = await ResolveCustomerIdAsync();
            CreateModel.CustomerId = parsedCustomerId;
            await AppointmentsApiClient.CreateAppointmentAsync(SessionState, CreateModel);
            FlashMessage = "Appointment created successfully.";
            SelectedCustomerId = string.Empty;
            QuickCustomerModel = new CreateCustomerRequestModel();
            ResetCreateModelForDate(SelectedScheduleDate);
            ShowCreateAppointmentModal = false;
            await LoadDataAsync();
        }
        catch (Exception ex) { ErrorMessage = ex.Message; }
        finally { IsBusy = false; }
    }

    private async Task CreateQuickCustomerAsync()
    {
        if (string.IsNullOrWhiteSpace(QuickCustomerModel.FullName) || string.IsNullOrWhiteSpace(QuickCustomerModel.Phone))
        {
            ErrorMessage = "Customer name and phone are required before booking an appointment.";
            FlashMessage = string.Empty;
            return;
        }

        IsBusy = true;
        ErrorMessage = string.Empty;
        FlashMessage = string.Empty;
        try
        {
            var customerId = await CustomersApiClient.CreateCustomerAsync(SessionState, QuickCustomerModel);
            QuickCustomerModel = new CreateCustomerRequestModel();
            await LoadDataAsync();
            SelectedCustomerId = customerId.ToString();
            FlashMessage = "Customer created and selected for the appointment.";
        }
        catch (Exception ex) { ErrorMessage = ex.Message; }
        finally { IsBusy = false; }
    }

    private void OpenManageAppointmentModal(AppointmentScheduleEntryModel item)
    {
        var source = AppointmentItems.FirstOrDefault(appointment => appointment.Id == item.Id);
        if (source is not null)
            OpenManageAppointmentModal(source);
    }

    private void OpenManageAppointmentModal(AppointmentListItemModel item)
    {
        SelectedAppointment = item;
        ManageAppointmentModel = new UpdateAppointmentRequestModel
        {
            CustomerId = item.CustomerId,
            ServiceId = item.ServiceId,
            StartAt = item.StartAt.ToLocalTime(),
            EndAt = item.EndAt.ToLocalTime(),
            ResourceName = item.ResourceName ?? string.Empty,
            Notes = item.Notes ?? string.Empty
        };
        ManageSelectedCustomerId = item.CustomerId?.ToString() ?? string.Empty;
        ManageSelectedServiceId = item.ServiceId?.ToString() ?? string.Empty;
        ShowManageAppointmentModal = true;
        ErrorMessage = string.Empty;
        FlashMessage = string.Empty;
    }

    private Task CloseManageAppointmentModal()
    {
        ShowManageAppointmentModal = false;
        SelectedAppointment = null;
        ManageAppointmentModel = new UpdateAppointmentRequestModel();
        ManageSelectedCustomerId = string.Empty;
        ManageSelectedServiceId = string.Empty;
        return Task.CompletedTask;
    }

    private async Task UpdateSelectedAppointmentAsync()
    {
        if (SelectedAppointment is null)
            return;

        if (!Guid.TryParse(ManageSelectedCustomerId, out var customerId))
        {
            ErrorMessage = "Select the appointment customer first.";
            FlashMessage = string.Empty;
            return;
        }

        if (!Guid.TryParse(ManageSelectedServiceId, out var serviceId))
        {
            ErrorMessage = "Select the appointment service first.";
            FlashMessage = string.Empty;
            return;
        }

        ManageAppointmentModel.CustomerId = customerId;
        ManageAppointmentModel.ServiceId = serviceId;

        IsBusy = true;
        ErrorMessage = string.Empty;
        FlashMessage = string.Empty;
        try
        {
            await AppointmentsApiClient.UpdateAppointmentAsync(SessionState, SelectedAppointment.Id, ManageAppointmentModel);
            FlashMessage = "Appointment updated successfully.";
            ShowManageAppointmentModal = false;
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task QuickMarkAppointmentStatusAsync(AppointmentListItemModel item, string status)
    {
        OpenManageAppointmentModal(item);
        await MarkSelectedAppointmentStatusAsync(status);
    }

    private async Task MarkSelectedAppointmentStatusAsync(string status)
    {
        if (SelectedAppointment is null)
            return;

        IsBusy = true;
        ErrorMessage = string.Empty;
        FlashMessage = string.Empty;
        try
        {
            await AppointmentsApiClient.UpdateStatusAsync(SessionState, SelectedAppointment.Id, new UpdateAppointmentStatusRequestModel { Status = status });
            FlashMessage = $"Appointment marked as {MapStatusLabel(status)}.";
            ShowManageAppointmentModal = false;
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task UpdateStatusAsync(AppointmentListItemModel item, string? newStatus)
    {
        if (string.IsNullOrWhiteSpace(newStatus)) return;

        IsBusy = true;
        ErrorMessage = string.Empty;
        FlashMessage = string.Empty;
        try
        {
            await AppointmentsApiClient.UpdateStatusAsync(SessionState, item.Id, new UpdateAppointmentStatusRequestModel { Status = newStatus });
            FlashMessage = "Appointment status updated successfully.";
            await LoadDataAsync();
        }
        catch (Exception ex) { ErrorMessage = ex.Message; }
        finally { IsBusy = false; }
    }

    private async Task LogoutAsync()
    {
        await SessionState.SignOutAsync();
        NavigationManager.NavigateTo("/");
    }

    private async Task<Guid> ResolveCustomerIdAsync()
    {
        if (Guid.TryParse(SelectedCustomerId, out var existingCustomerId))
            return existingCustomerId;

        if (string.IsNullOrWhiteSpace(QuickCustomerModel.FullName) || string.IsNullOrWhiteSpace(QuickCustomerModel.Phone))
            throw new InvalidOperationException("Customer name and phone are required for a new appointment.");

        var customerId = await CustomersApiClient.CreateCustomerAsync(SessionState, QuickCustomerModel);
        SelectedCustomerId = customerId.ToString();
        return customerId;
    }

    private void SelectResource(string resourceName)
    {
        CreateModel.ResourceName = resourceName;
        FlashMessage = string.Empty;
        ErrorMessage = string.Empty;
    }

    private void SelectSlot(DateTime slotStart)
    {
        SelectedSlotStart = slotStart;
        CreateModel.StartAt = slotStart;
        CreateModel.EndAt = slotStart.AddMinutes(SelectedDurationMinutes);
        ShowCreateAppointmentModal = true;
        FlashMessage = string.Empty;
        ErrorMessage = string.Empty;
    }

    private void OpenCreateAppointmentModal()
    {
        ShowCreateAppointmentModal = true;
        FlashMessage = string.Empty;
        ErrorMessage = string.Empty;
    }

    private Task CloseCreateAppointmentModal()
    {
        ShowCreateAppointmentModal = false;
        return Task.CompletedTask;
    }

    private bool IsSelectedSlot(DateTime slotStart)
        => CreateModel.StartAt == slotStart;

    private bool IsSlotOccupied(DateTime slotStart)
    {
        var slotEnd = slotStart.AddMinutes(SelectedDurationMinutes);
        return GetSelectedResourceItems()
            .Any(item =>
            {
                var itemStart = item.StartAt.ToLocalTime();
                var itemEnd = item.EndAt.ToLocalTime();
                return slotStart < itemEnd && slotEnd > itemStart;
            });
    }

    private IReadOnlyList<AppointmentScheduleEntryModel> GetSelectedResourceItems()
    {
        var resourceName = string.IsNullOrWhiteSpace(CreateModel.ResourceName) ? "Unassigned" : CreateModel.ResourceName.Trim();
        var column = ScheduleColumns.FirstOrDefault(x => string.Equals(x.ResourceName, resourceName, StringComparison.OrdinalIgnoreCase))
                     ?? ScheduleColumns.FirstOrDefault(x => x.IsUnassigned);
        return column?.Items ?? [];
    }

    private IReadOnlyList<DateTime> BuildAvailableSlots()
    {
        var start = SelectedScheduleDate.Date.AddHours(SchedulerStartHour);
        var end = SelectedScheduleDate.Date.AddHours(SchedulerEndHour);
        var slots = new List<DateTime>();
        var cursor = start;
        while (cursor.AddMinutes(SelectedDurationMinutes) <= end)
        {
            slots.Add(cursor);
            cursor = cursor.AddMinutes(30);
        }

        return slots;
    }

    private void ResetCreateModelForDate(DateTime date)
    {
        SelectedSlotStart = null;
        CreateModel = CreateDefaultAppointmentModel(date);
    }

    private static CreateAppointmentRequestModel CreateDefaultAppointmentModel(DateTime date)
    {
        var start = date.Date.AddHours(12);
        return new CreateAppointmentRequestModel
        {
            ServiceId = null,
            StartAt = start,
            EndAt = start.AddHours(1),
            Notes = string.Empty,
            ResourceName = string.Empty
        };
    }

    private static string FormatHourLabel(int hour) => DateTime.Today.AddHours(hour).ToString("htt").ToLowerInvariant();

    private static string MapStatusLabel(string status)
        => status switch
        {
            "scheduled" => "Scheduled",
            "confirmed" => "Confirmed",
            "completed" => "Completed",
            "cancelled" => "Cancelled",
            "no_show" => "No Show",
            _ => status
        };

    private static string GetAppointmentStatusClass(string status)
        => status switch
        {
            "confirmed" => "appointment-status-confirmed",
            "completed" => "appointment-status-completed",
            "cancelled" => "appointment-status-cancelled",
            "no_show" => "appointment-status-no-show",
            _ => "appointment-status-scheduled"
        };

    private string GetLaneBackgroundStyle()
    {
        var hourHeight = 60d * PixelsPerMinute;
        return $"height:{(SchedulerEndHour - SchedulerStartHour) * hourHeight:0}px;background-image: repeating-linear-gradient(to bottom, rgba(151,118,96,0.10) 0, rgba(151,118,96,0.10) 1px, transparent 1px, transparent {hourHeight:0}px);";
    }

    private string GetAppointmentCardStyle(AppointmentScheduleEntryModel item, string specialistKey)
    {
        var localStart = item.StartAt.ToLocalTime();
        var localEnd = item.EndAt.ToLocalTime();
        var scheduleStart = SelectedScheduleDate.Date.AddHours(SchedulerStartHour);
        var topMinutes = Math.Max(0d, (localStart - scheduleStart).TotalMinutes);
        var durationMinutes = Math.Max(35d, (localEnd - localStart).TotalMinutes);
        return $"top:{topMinutes * PixelsPerMinute:0}px;height:{durationMinutes * PixelsPerMinute:0}px;{BuildSpecialistColorStyle(specialistKey)}";
    }

    private static string GetServiceDisplayName(ServiceListItemModel service)
        => !string.IsNullOrWhiteSpace(service.NameEn)
            ? service.NameEn
            : !string.IsNullOrWhiteSpace(service.NameAr)
                ? service.NameAr
                : "Unnamed service";

    private string GetAgendaItemStyle(AppointmentListItemModel item)
        => BuildSpecialistColorStyle(string.IsNullOrWhiteSpace(item.ResourceName) ? item.CustomerName : item.ResourceName);

    private static string BuildSpecialistColorStyle(string key)
    {
        var palette = new[]
        {
            ("#9ad6ff", "#72b6eb"),
            ("#b9ef95", "#8fda69"),
            ("#ffc09f", "#f39d7a"),
            ("#dbc6ff", "#bfa5f2"),
            ("#f7c4de", "#ea93c5"),
            ("#ffe29a", "#f2bf59"),
            ("#b4efe5", "#7bd5c6")
        };

        var index = Math.Abs((key ?? string.Empty).GetHashCode()) % palette.Length;
        var (from, to) = palette[index];
        return $"background:linear-gradient(180deg, {from} 0%, {to} 100%);";
    }

    private IReadOnlyList<WeeklyAgendaDay> BuildWeeklyAgendaDays()
    {
        var start = StartOfWeek(SelectedScheduleDate);
        return Enumerable.Range(0, 7)
            .Select(offset =>
            {
                var day = start.AddDays(offset);
                return new WeeklyAgendaDay(
                    day,
                    AppointmentItems
                        .Where(item => item.StartAt.ToLocalTime().Date == day.Date)
                        .OrderBy(item => item.StartAt)
                        .ToList());
            })
            .ToList();
    }

    private IReadOnlyList<AgendaDayGroup> BuildAgendaGroups()
    {
        return AppointmentItems
            .OrderBy(item => item.StartAt)
            .GroupBy(item => item.StartAt.ToLocalTime().Date)
            .Select(group => new AgendaDayGroup(group.Key, group.OrderBy(item => item.StartAt).ToList()))
            .ToList();
    }

    private static DateTime StartOfWeek(DateTime date)
    {
        var diff = (7 + (date.DayOfWeek - DayOfWeek.Monday)) % 7;
        return date.Date.AddDays(-diff);
    }

    private sealed record WeeklyAgendaDay(DateTime Date, List<AppointmentListItemModel> Items);
    private sealed record AgendaDayGroup(DateTime Date, List<AppointmentListItemModel> Items);
}
