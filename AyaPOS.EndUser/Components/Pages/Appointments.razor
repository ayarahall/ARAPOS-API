@page "/appointments"
@rendermode InteractiveServer
@using Ayapos.EndUser.Models.Appointments
@using Ayapos.EndUser.Models.Customers
@using Ayapos.EndUser.Models.Services
@using Ayapos.EndUser.Services.Auth
@using Ayapos.EndUser.Services.Appointments
@using Ayapos.EndUser.Services.Customers
@using Ayapos.EndUser.Services.Services
@inject NavigationManager NavigationManager
@inject SessionState SessionState
@inject AppointmentsApiClient AppointmentsApiClient
@inject CustomersApiClient CustomersApiClient
@inject ServicesApiClient ServicesApiClient

<PageTitle>Appointments</PageTitle>

<div class="products-page">
    <AppPageHeader Title="Appointments" Description="Manage daily booking flow at branch level, separate from owner and tenant administration." SessionState="@SessionState" OnLogout="LogoutAsync" />

    <RoleAwareSectionTabs Current="appointments" />

    <NotificationPopup SuccessMessage="@FlashMessage" ErrorMessage="@ErrorMessage" />

    <section class="showcase-panel">
        <div class="showcase-header">
            <div>
                <span class="eyebrow">Branch Calendar</span>
                <h2>@AppointmentsTitle</h2>
            </div>
            <p>@AppointmentsDescription</p>
        </div>
    </section>

    <section class="metrics-grid">
        <article class="metric-card">
            <span class="metric-label">Scope</span>
            <strong class="metric-value">Branch Level</strong>
            <span class="metric-note">Appointments belong to the operating branch, not the platform admin area.</span>
        </article>

        <article class="metric-card">
            <span class="metric-label">Focus</span>
            <strong class="metric-value">@AppointmentFocus</strong>
            <span class="metric-note">The screen supports reception, specialists, and branch scheduling.</span>
        </article>

        <article class="metric-card">
            <span class="metric-label">Current Branch</span>
            <strong class="metric-value">@BranchLabel</strong>
            <span class="metric-note">The selected branch context from the signed-in session.</span>
        </article>

        <article class="metric-card accent">
            <span class="metric-label">Appointments</span>
            <strong class="metric-value">@TotalCount</strong>
            <span class="metric-note">Appointments loaded for @SelectedScheduleDate.ToString("dddd, dd MMM yyyy").</span>
        </article>
    </section>

    <section class="showcase-panel">
        <div class="showcase-header">
            <div>
                <span class="eyebrow">Booking Flow</span>
                <h2>Open a booking popup from the scheduler</h2>
            </div>
            <p>Choose the date, pick the specialist column, then click a free slot. The customer and service details open in a focused popup instead of stretching the whole page.</p>
        </div>

        <div class="metrics-grid" style="margin-top:18px;">
            <article class="metric-card">
                <span class="metric-label">Step 1</span>
                <strong class="metric-value">Pick Specialist</strong>
                <span class="metric-note">Choose the target specialist column or keep the booking unassigned.</span>
            </article>

            <article class="metric-card">
                <span class="metric-label">Step 2</span>
                <strong class="metric-value">Pick Slot</strong>
                <span class="metric-note">Select a free slot and we open the create-booking popup for that exact time.</span>
            </article>

            <article class="metric-card accent">
                <span class="metric-label">Step 3</span>
                <strong class="metric-value">Customer + Service</strong>
                <span class="metric-note">Customer name and phone stay mandatory for new appointments inside the tenant and branch.</span>
            </article>
        </div>

        <div class="invoice-actions" style="margin-top:16px;">
            <button type="button" class="submit-button" @onclick="OpenCreateAppointmentModal" disabled="@IsBusy">New Appointment</button>
            <button type="button" class="ghost-button" @onclick="RefreshAsync" disabled="@IsBusy">Refresh Appointments</button>
        </div>
    </section>

    <section class="showcase-panel">
        <div class="showcase-header">
            <div>
                <span class="eyebrow">Scheduler</span>
                <h2>Daily appointments by specialist</h2>
            </div>
            <p>This board follows the branch working day and gives each specialist or resource a separate vertical lane, similar to a salon or clinic scheduler.</p>
        </div>

        <div class="scheduler-topbar">
            <div class="scheduler-nav">
                <button type="button" class="ghost-button" @onclick="LoadPreviousDayAsync" disabled="@IsBusy">Previous Day</button>
                <button type="button" class="ghost-button" @onclick="LoadTodayAsync" disabled="@IsBusy">Today</button>
                <button type="button" class="ghost-button" @onclick="LoadNextDayAsync" disabled="@IsBusy">Next Day</button>
            </div>

            <div class="scheduler-nav">
                <button type="button" class="ghost-button @(ScheduleMode == "day" ? "active-filter-button" : string.Empty)" @onclick='() => ChangeScheduleModeAsync("day")' disabled="@IsBusy">Day View</button>
                <button type="button" class="ghost-button @(ScheduleMode == "week" ? "active-filter-button" : string.Empty)" @onclick='() => ChangeScheduleModeAsync("week")' disabled="@IsBusy">Week View</button>
                <button type="button" class="ghost-button @(ScheduleMode == "agenda" ? "active-filter-button" : string.Empty)" @onclick='() => ChangeScheduleModeAsync("agenda")' disabled="@IsBusy">Agenda</button>
                <button type="button" class="ghost-button" @onclick="OpenCreateAppointmentModal" disabled="@IsBusy">New Appointment</button>
                <button type="button" class="ghost-button" @onclick="RefreshAsync" disabled="@IsBusy">Reload</button>
            </div>

            <div class="scheduler-date-wrap">
                <label for="scheduleDatePicker" class="metric-label">Schedule Date</label>
                <input id="scheduleDatePicker" class="form-input compact-input" type="date" value="@SelectedScheduleDate.ToString("yyyy-MM-dd")" @onchange="OnScheduleDateChanged" />
            </div>
        </div>

        @if (ScheduleMode == "day")
        {
        <div class="scheduler-shell">
            <aside class="scheduler-sidebar">
                <div class="scheduler-sidebar-card">
                    <div class="scheduler-sidebar-title">Day Summary</div>
                    <div class="scheduler-sidebar-value">@SelectedScheduleDate.ToString("dddd")</div>
                    <div class="scheduler-sidebar-note">@SelectedScheduleDate.ToString("dd MMMM yyyy")</div>
                </div>

                <div class="scheduler-sidebar-card">
                    <div class="scheduler-sidebar-title">Specialists</div>
                    <div class="scheduler-sidebar-value">@ScheduleColumns.Count</div>
                    <div class="scheduler-sidebar-note">Separate columns currently visible in the board.</div>
                </div>

                <div class="scheduler-sidebar-card">
                    <div class="scheduler-sidebar-title">Loaded Bookings</div>
                    <div class="scheduler-sidebar-value">@ScheduleColumns.Sum(column => column.Items.Count)</div>
                    <div class="scheduler-sidebar-note">Appointments plotted across all resources for this day.</div>
                </div>

                <div class="scheduler-sidebar-card">
                    <div class="scheduler-sidebar-title">Unassigned</div>
                    <div class="scheduler-sidebar-value">@(ScheduleColumns.FirstOrDefault(column => column.IsUnassigned)?.Items.Count ?? 0)</div>
                    <div class="scheduler-sidebar-note">Visits still waiting for a named specialist.</div>
                </div>
            </aside>

            @if (ScheduleColumns.Count == 0)
            {
                <div class="placeholder-panel" style="width:100%;">No resources or appointments are available for the selected date yet.</div>
            }
            else
            {
                <div class="scheduler-board-wrap">
                    <div class="scheduler-grid" style="@SchedulerColumnsStyle">
                        <div class="scheduler-time-column">
                            <div class="scheduler-time-header">Time</div>
                            @foreach (var label in HourLabels)
                            {
                                <div class="scheduler-time-slot">@label</div>
                            }
                        </div>

                        @foreach (var column in ScheduleColumns)
                        {
                            <div class="scheduler-resource-column">
                                <div class="scheduler-resource-header">
                                    <strong>@column.ResourceName</strong>
                                    <span>@(column.IsUnassigned ? "Open pool" : string.IsNullOrWhiteSpace(column.Role) ? "Resource" : column.Role)</span>
                                </div>

                                <div class="scheduler-lane" style="@GetLaneBackgroundStyle()">
                                    @foreach (var item in column.Items)
                                    {
                                        <article class="scheduler-appointment-card @GetAppointmentStatusClass(item.Status)" style="@GetAppointmentCardStyle(item, column.ResourceName)" @onclick="() => OpenManageAppointmentModal(item)">
                                            <div class="scheduler-appointment-time">@item.StartAt.ToLocalTime().ToString("HH:mm") - @item.EndAt.ToLocalTime().ToString("HH:mm")</div>
                                            <div class="scheduler-appointment-title">@(string.IsNullOrWhiteSpace(item.CustomerName) ? "Walk-in" : item.CustomerName)</div>
                                            @if (!string.IsNullOrWhiteSpace(item.ServiceName))
                                            {
                                                <div class="scheduler-appointment-meta">@item.ServiceName</div>
                                            }
                                            <div class="scheduler-appointment-meta">@(string.IsNullOrWhiteSpace(item.CustomerPhone) ? "No phone" : item.CustomerPhone)</div>
                                            <div class="scheduler-appointment-meta">@MapStatusLabel(item.Status)</div>
                                            @if (!string.IsNullOrWhiteSpace(item.Notes))
                                            {
                                                <div class="scheduler-appointment-notes">@item.Notes</div>
                                            }
                                        </article>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
        }
        else if (ScheduleMode == "week")
        {
            <div class="products-table-wrap" style="margin-top:20px;">
                @if (WeeklyAgendaDays.Count == 0)
                {
                    <div class="placeholder-panel">No appointments are available for the selected week yet.</div>
                }
                else
                {
                    <div class="agenda-week-grid">
                        @foreach (var day in WeeklyAgendaDays)
                        {
                            <section class="agenda-day-card">
                                <div class="agenda-day-header">
                                    <strong>@day.Date.ToString("dddd")</strong>
                                    <span>@day.Date.ToString("dd MMM yyyy")</span>
                                </div>

                                @if (day.Items.Count == 0)
                                {
                                    <div class="table-secondary-cell">No bookings for this day.</div>
                                }
                                else
                                {
                                    @foreach (var item in day.Items)
                                    {
                                        <article class="agenda-item-card" style="@GetAgendaItemStyle(item)" @onclick="() => OpenManageAppointmentModal(item)">
                                            <div class="agenda-item-time">@item.StartAt.ToLocalTime().ToString("HH:mm") - @item.EndAt.ToLocalTime().ToString("HH:mm")</div>
                                            <div class="agenda-item-title">@(string.IsNullOrWhiteSpace(item.CustomerName) ? "Walk-in" : item.CustomerName)</div>
                                            <div class="agenda-item-meta">@(!string.IsNullOrWhiteSpace(item.ServiceName) ? item.ServiceName : "No service")</div>
                                            <div class="agenda-item-meta">@(!string.IsNullOrWhiteSpace(item.ResourceName) ? item.ResourceName : "Unassigned")</div>
                                        </article>
                                    }
                                }
                            </section>
                        }
                    </div>
                }
            </div>
        }
        else
        {
            <div class="products-table-wrap" style="margin-top:20px;">
                @if (AgendaGroups.Count == 0)
                {
                    <div class="placeholder-panel">No appointments are available for the current agenda range yet.</div>
                }
                else
                {
                    @foreach (var group in AgendaGroups)
                    {
                        <section class="agenda-day-card" style="margin-bottom:16px;">
                            <div class="agenda-day-header">
                                <strong>@group.Date.ToString("dddd")</strong>
                                <span>@group.Date.ToString("dd MMM yyyy")</span>
                            </div>

                            <div class="products-table-wrap" style="margin-top:12px;">
                                <table class="products-table">
                                    <thead>
                                        <tr>
                                            <th>Time</th>
                                            <th>Customer</th>
                                            <th>Phone</th>
                                            <th>Service</th>
                                            <th>Specialist</th>
                                            <th>Status</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in group.Items)
                                        {
                                            <tr>
                                                <td>@item.StartAt.ToLocalTime().ToString("HH:mm") - @item.EndAt.ToLocalTime().ToString("HH:mm")</td>
                                                <td>@(string.IsNullOrWhiteSpace(item.CustomerName) ? "Walk-in" : item.CustomerName)</td>
                                                <td>@(string.IsNullOrWhiteSpace(item.CustomerPhone) ? "No phone" : item.CustomerPhone)</td>
                                                <td>@(!string.IsNullOrWhiteSpace(item.ServiceName) ? item.ServiceName : "No service")</td>
                                                <td>@(!string.IsNullOrWhiteSpace(item.ResourceName) ? item.ResourceName : "Unassigned")</td>
                                                <td>@MapStatusLabel(item.Status)</td>
                                                <td>
                                                    <button type="button" class="ghost-button" @onclick="() => OpenManageAppointmentModal(item)">Manage</button>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </section>
                    }
                }
            </div>
        }
    </section>

    <section class="products-table-wrap">
        @if (AppointmentItems.Count == 0)
        {
            <div class="placeholder-panel" style="margin-top:20px;">No appointments loaded for this branch yet.</div>
        }
        else
        {
            <table class="products-table">
                <thead>
                    <tr>
                        <th>Customer</th>
                        <th>Service</th>
                        <th>Resource</th>
                        <th>Start</th>
                        <th>End</th>
                        <th>Status</th>
                        <th>Notes</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in AppointmentItems)
                    {
                        <tr>
                            <td>
                                <div class="table-primary-cell">@(string.IsNullOrWhiteSpace(item.CustomerName) ? "Walk-in" : item.CustomerName)</div>
                                <div class="table-secondary-cell">@(string.IsNullOrWhiteSpace(item.CustomerPhone) ? "No phone" : item.CustomerPhone)</div>
                            </td>
                            <td>
                                <div class="table-primary-cell">@(string.IsNullOrWhiteSpace(item.ServiceName) ? "-" : item.ServiceName)</div>
                                <div class="table-secondary-cell">@(item.ServicePrice is null ? string.Empty : $"{item.ServicePrice:0.##} {item.CurrencyCode}")</div>
                            </td>
                            <td>@(string.IsNullOrWhiteSpace(item.ResourceName) ? "Unassigned" : item.ResourceName)</td>
                            <td>@item.StartAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@item.EndAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                <select class="form-input compact-input" value="@item.Status" @onchange="args => UpdateStatusAsync(item, args.Value?.ToString())">
                                    @foreach (var status in AppointmentStatuses)
                                    {
                                        <option value="@status">@MapStatusLabel(status)</option>
                                    }
                                </select>
                            </td>
                            <td>@(string.IsNullOrWhiteSpace(item.Notes) ? "-" : item.Notes)</td>
                            <td>
                                <div class="invoice-actions" style="gap:8px;">
                                    <button type="button" class="ghost-button" @onclick="() => OpenManageAppointmentModal(item)">Edit</button>
                                    <button type="button" class="ghost-button" @onclick='() => QuickMarkAppointmentStatusAsync(item, "cancelled")' disabled="@IsBusy">Cancel</button>
                                    <button type="button" class="ghost-button" @onclick='() => QuickMarkAppointmentStatusAsync(item, "no_show")' disabled="@IsBusy">No Show</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>

    <ActionModal Visible="@ShowCreateAppointmentModal"
                 Eyebrow="New Appointment"
                 Title="Create appointment for this branch"
                 Description="Pick the specialist, confirm the time slot, then attach an existing customer or create a new one with required name and phone."
                 OnClose="CloseCreateAppointmentModal">
        <div class="metrics-grid">
            <article class="metric-card">
                <span class="metric-label">Window</span>
                <strong class="metric-value">@AppointmentWindowLabel</strong>
                <span class="metric-note">@(!HasSelectedSlot ? "Pick a free slot from the scheduler or the list below." : "This slot is now locked for the booking flow until you save or close.")</span>
            </article>

            <article class="metric-card">
                <span class="metric-label">Assigned To</span>
                <strong class="metric-value">@(string.IsNullOrWhiteSpace(CreateModel.ResourceName) ? "Unassigned" : CreateModel.ResourceName)</strong>
                <span class="metric-note">Each specialist gets a separate column in the branch board.</span>
            </article>

            <article class="metric-card accent">
                <span class="metric-label">Selected Service</span>
                <strong class="metric-value">@(SelectedService is null ? "No service" : GetServiceDisplayName(SelectedService))</strong>
                <span class="metric-note">@(SelectedService is null ? "Choose a branch service before saving the appointment." : $"{SelectedService.Price:0.##} {SelectedService.CurrencyCode}")</span>
            </article>
        </div>

        <div class="showcase-header">
            <div>
                <span class="eyebrow">Step 1</span>
                <h2>Select specialist and timing</h2>
            </div>
            <p>Bookings remain inside the current tenant and branch, while the chosen specialist controls the scheduler column.</p>
        </div>

        <div class="invoice-form-grid">
            <div class="field">
                <label for="scheduleDatePickerCreate">Schedule Date</label>
                <input id="scheduleDatePickerCreate" class="form-input" type="date" value="@SelectedScheduleDate.ToString("yyyy-MM-dd")" @onchange="OnScheduleDateChanged" />
            </div>

            <div class="field">
                <label for="appointmentResource">Specialist / Resource</label>
                <select id="appointmentResource" class="form-input" @bind="CreateModel.ResourceName">
                    <option value="">Unassigned resource</option>
                    @foreach (var resource in ResourceOptions)
                    {
                        <option value="@resource.Username">@resource.Username (@resource.Role)</option>
                    }
                </select>
            </div>

            <div class="field">
                <label for="appointmentService">Service</label>
                <select id="appointmentService" class="form-input" @bind="SelectedServiceId">
                    <option value="">Select branch service</option>
                    @foreach (var service in ServiceOptions)
                    {
                        <option value="@service.Id">@GetServiceDisplayName(service) (@service.Price:0.## @service.CurrencyCode)</option>
                    }
                </select>
            </div>

            <div class="field">
                <label for="appointmentStartAt">Selected Start</label>
                <input id="appointmentStartAt" class="form-input" type="datetime-local" value="@StartAtInput" @onchange="OnStartAtChanged" />
            </div>

            <div class="field">
                <label for="appointmentEndAt">Selected End</label>
                <input id="appointmentEndAt" class="form-input" type="datetime-local" value="@EndAtInput" @onchange="OnEndAtChanged" />
            </div>
        </div>

        <div class="resource-chip-grid">
            <button type="button"
                    class="resource-chip @(string.IsNullOrWhiteSpace(CreateModel.ResourceName) ? "resource-chip-active" : string.Empty)"
                    @onclick='() => SelectResource(string.Empty)'>
                <strong>Unassigned</strong>
                <span>Open lane</span>
            </button>
            @foreach (var resource in ResourceOptions)
            {
                <button type="button"
                        class="resource-chip @(string.Equals(CreateModel.ResourceName, resource.Username, StringComparison.OrdinalIgnoreCase) ? "resource-chip-active" : string.Empty)"
                        style="@BuildSpecialistColorStyle(resource.Username)"
                        @onclick='() => SelectResource(resource.Username)'>
                    <strong>@resource.Username</strong>
                    <span>@resource.Role</span>
                </button>
            }
        </div>

        <div class="slot-picker-grid">
            @foreach (var slot in AvailableSlots)
            {
                var occupied = IsSlotOccupied(slot);
                <button type="button"
                        class="slot-button @(IsSelectedSlot(slot) ? "slot-button-selected" : string.Empty) @(occupied ? "slot-button-busy" : string.Empty)"
                        disabled="@occupied"
                        @onclick="() => SelectSlot(slot)">
                    <span>@slot.ToString("HH:mm")</span>
                    <small>@(occupied ? "Busy" : "Free")</small>
                </button>
            }
        </div>

        <div class="showcase-header">
            <div>
                <span class="eyebrow">Step 2</span>
                <h2>Customer details</h2>
            </div>
            <p>Attach an existing customer or create a new one from the same popup. Name and phone are mandatory for any new booking.</p>
        </div>

        <div class="invoice-form-grid">
            <div class="field">
                <label for="appointmentCustomerSearch">Customer Search</label>
                <input id="appointmentCustomerSearch" class="form-input" @bind="CustomerSearchText" @bind:event="oninput" placeholder="Search by name or phone" />
            </div>

            <div class="field">
                <label for="appointmentCustomer">Existing Customer (optional)</label>
                <select id="appointmentCustomer" class="form-input" @bind="SelectedCustomerId">
                    <option value="">Create from the customer details form</option>
                    @foreach (var customer in FilteredCustomerOptions)
                    {
                        <option value="@customer.Id">@customer.FullName (@(string.IsNullOrWhiteSpace(customer.Phone) ? "No phone" : customer.Phone))</option>
                    }
                </select>
            </div>

            <div class="field">
                <label for="appointmentQuickCustomerName">Full Name</label>
                <input id="appointmentQuickCustomerName" class="form-input" @bind="QuickCustomerModel.FullName" />
            </div>

            <div class="field">
                <label for="appointmentQuickCustomerPhone">Phone</label>
                <input id="appointmentQuickCustomerPhone" class="form-input" @bind="QuickCustomerModel.Phone" />
            </div>

            <div class="field">
                <label for="appointmentQuickCustomerEmail">Email</label>
                <input id="appointmentQuickCustomerEmail" class="form-input" @bind="QuickCustomerModel.Email" />
            </div>

            <div class="field">
                <label for="appointmentQuickCustomerNotes">Customer Notes</label>
                <input id="appointmentQuickCustomerNotes" class="form-input" @bind="QuickCustomerModel.Notes" />
            </div>

            <div class="field">
                <label for="appointmentNotes">Appointment Notes</label>
                <input id="appointmentNotes" class="form-input" @bind="CreateModel.Notes" placeholder="Optional appointment notes" />
            </div>
        </div>

        <div class="metrics-grid">
            <article class="metric-card">
                <span class="metric-label">Selected Customer</span>
                <strong class="metric-value">@(SelectedCustomer?.FullName ?? "No customer")</strong>
                <span class="metric-note">@((SelectedCustomer is null) ? "A new customer will be created from the entered name and phone." : "This existing customer will be attached to the appointment.")</span>
            </article>

            <article class="metric-card">
                <span class="metric-label">Phone</span>
                <strong class="metric-value">@(SelectedCustomer is null ? (string.IsNullOrWhiteSpace(QuickCustomerModel.Phone) ? "Missing" : QuickCustomerModel.Phone) : string.IsNullOrWhiteSpace(SelectedCustomer.Phone) ? "Missing" : SelectedCustomer.Phone)</strong>
                <span class="metric-note">Phone is mandatory so the branch can confirm, remind, or reschedule.</span>
            </article>
        </div>

        <div class="invoice-actions">
            <button type="button" class="submit-button" @onclick="CreateAppointmentAsync" disabled="@IsBusy">Create Appointment</button>
            <button type="button" class="ghost-button" @onclick="CreateQuickCustomerAsync" disabled="@IsBusy">Create Customer Only</button>
            <button type="button" class="ghost-button" @onclick="CloseCreateAppointmentModal" disabled="@IsBusy">Close</button>
        </div>
    </ActionModal>

    <ActionModal Visible="@(ShowManageAppointmentModal && SelectedAppointment is not null)"
                 Eyebrow="Manage Appointment"
                 Title="@ManageAppointmentTitle"
                 Description="Edit the booking from the same scheduler flow, or mark it as cancelled or no-show without leaving the table."
                 OnClose="CloseManageAppointmentModal">
        @if (SelectedAppointment is not null)
        {
            <div class="invoice-form-grid">
                <div class="field">
                    <label for="manageAppointmentCustomer">Customer</label>
                    <select id="manageAppointmentCustomer" class="form-input" @bind="ManageSelectedCustomerId">
                        <option value="">Select customer</option>
                        @foreach (var customer in CustomerOptions)
                        {
                            <option value="@customer.Id">@customer.FullName (@(string.IsNullOrWhiteSpace(customer.Phone) ? "No phone" : customer.Phone))</option>
                        }
                    </select>
                </div>

                <div class="field">
                    <label for="manageAppointmentService">Service</label>
                    <select id="manageAppointmentService" class="form-input" @bind="ManageSelectedServiceId">
                        <option value="">Select service</option>
                        @foreach (var service in ServiceOptions)
                        {
                            <option value="@service.Id">@GetServiceDisplayName(service) (@service.Price:0.## @service.CurrencyCode)</option>
                        }
                    </select>
                </div>

                <div class="field">
                    <label for="manageAppointmentResource">Specialist / Resource</label>
                    <select id="manageAppointmentResource" class="form-input" @bind="ManageAppointmentModel.ResourceName">
                        <option value="">Unassigned resource</option>
                        @foreach (var resource in ResourceOptions)
                        {
                            <option value="@resource.Username">@resource.Username (@resource.Role)</option>
                        }
                    </select>
                </div>

                <div class="field">
                    <label for="manageAppointmentStartAt">Start</label>
                    <input id="manageAppointmentStartAt" class="form-input" type="datetime-local" value="@ManageStartAtInput" @onchange="OnManageStartAtChanged" />
                </div>

                <div class="field">
                    <label for="manageAppointmentEndAt">End</label>
                    <input id="manageAppointmentEndAt" class="form-input" type="datetime-local" value="@ManageEndAtInput" @onchange="OnManageEndAtChanged" />
                </div>

                <div class="field">
                    <label for="manageAppointmentNotes">Notes</label>
                    <input id="manageAppointmentNotes" class="form-input" @bind="ManageAppointmentModel.Notes" />
                </div>
            </div>

            <div class="invoice-actions">
                <button type="button" class="submit-button" @onclick="UpdateSelectedAppointmentAsync" disabled="@IsBusy">Save Changes</button>
                <button type="button" class="ghost-button" @onclick='() => MarkSelectedAppointmentStatusAsync("cancelled")' disabled="@IsBusy">Cancel Appointment</button>
                <button type="button" class="ghost-button" @onclick='() => MarkSelectedAppointmentStatusAsync("no_show")' disabled="@IsBusy">Mark No Show</button>
                <button type="button" class="ghost-button" @onclick="CloseManageAppointmentModal" disabled="@IsBusy">Close</button>
            </div>
        }
    </ActionModal>
</div>

